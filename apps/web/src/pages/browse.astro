---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Browse reviews"
  description="Browse Ureview by arxiv math category and date."
  activeNav="browse"
>
  <div class="container">
    <section class="page-intro page-intro--prose">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span>Browse</span>
      </nav>
      <span class="page-intro-eyebrow">Index · Filterable</span>
      <h1 class="page-intro-title">Browse the feed.</h1>
      <p class="page-intro-lede">
        Always ranked by E[impact] = impact × correctness. Filter by quadrant
        (where the trade-off lives) or by math sub-category.
      </p>
    </section>

    <section class="filter-bar" id="filter-bar" aria-label="Filter reviews">
      <div class="filter-row" data-filter="quadrant">
        <span class="filter-label">Quadrant</span>
        <div class="filter-chips-wrap"></div>
      </div>
      <div class="filter-row" data-filter="categories">
        <span class="filter-label">Category</span>
        <div class="filter-chips-wrap"></div>
      </div>
    </section>

    <div class="browse-count" id="browse-count" aria-live="polite">Loading…</div>

    <section class="entry-list" id="browse-list" aria-live="polite">
      {Array.from({ length: 5 }).map(() => (
        <div class="entry entry--skel" aria-hidden="true">
          <span class="entry-kicker"><span class="skel-block skel-line-xs"></span></span>
          <span class="entry-title"><span class="skel-block skel-title"></span></span>
          <div class="entry-footer"><span class="skel-block skel-line-sm" style="width:30%"></span></div>
        </div>
      ))}
    </section>

    <div class="state empty" id="browse-empty-state" hidden>
      <strong>No reviews match this combination</strong>
      <button type="button" class="btn-secondary btn-secondary--compact" id="browse-reset">Reset filters</button>
    </div>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { buildFeedCard } from '../lib/feed-card';
  import { expectedImpact } from '../lib/types';
  import type { LatestReviewEntry } from '../lib/types';

  function timeAgo(iso: string): string {
    const ts = Date.parse(iso);
    if (Number.isNaN(ts)) return iso;
    const diff = Date.now() - ts;
    const min = Math.round(diff / 60_000);
    if (min < 1) return 'just now';
    if (min < 60) return `${min}m ago`;
    const hr = Math.round(min / 60);
    if (hr < 24) return `${hr}h ago`;
    const day = Math.round(hr / 24);
    if (day < 30) return `${day}d ago`;
    return new Date(ts).toLocaleDateString();
  }

  // Quadrants of (impact × correctness). Mathematicians read these very
  // differently: "high-impact / shaky proof" is the dragon-hunting feed,
  // "low-impact / solid" is the increment crowd.
  type Quadrant = 'all' | 'top' | 'dragons' | 'solid';

  const HIGH_IMPACT = new Set(['max', 'high']);
  const HIGH_CORRECT = new Set(['max', 'high']);
  const LOW_CORRECT = new Set(['low', 'minimal']);

  const QUADRANTS: Array<{ key: Quadrant; label: string; match: (e: LatestReviewEntry) => boolean }> = [
    { key: 'all',     label: 'All',                  match: () => true },
    { key: 'top',     label: 'Top: high × high',     match: (e) => HIGH_IMPACT.has(e.impact_if_true) && HIGH_CORRECT.has(e.proof_correctness) },
    { key: 'dragons', label: 'Dragons: high × low',  match: (e) => HIGH_IMPACT.has(e.impact_if_true) && LOW_CORRECT.has(e.proof_correctness) },
    { key: 'solid',   label: 'Solid: low × high',    match: (e) => !HIGH_IMPACT.has(e.impact_if_true) && HIGH_CORRECT.has(e.proof_correctness) },
  ];

  const DEFAULT_QUADRANT: Quadrant = 'all';

  const state = {
    categories: new Set<string>(),
    quadrant: DEFAULT_QUADRANT,
  };

  function readStateFromUrl() {
    const params = new URLSearchParams(window.location.search);
    state.categories = new Set((params.get('cat') ?? '').split(',').map((s) => s.trim()).filter(Boolean));
    const q = params.get('q') as Quadrant | null;
    state.quadrant = QUADRANTS.find((o) => o.key === q)?.key ?? DEFAULT_QUADRANT;
  }

  function writeStateToUrl() {
    const url = new URL(window.location.href);
    const setOrDelete = (name: string, value: string) => {
      if (value) url.searchParams.set(name, value);
      else url.searchParams.delete(name);
    };
    setOrDelete('cat', [...state.categories].join(','));
    setOrDelete('q', state.quadrant === DEFAULT_QUADRANT ? '' : state.quadrant);
    history.replaceState({}, '', url);
  }

  function resetState() {
    state.categories.clear();
    state.quadrant = DEFAULT_QUADRANT;
  }

  function chip(opts: {
    label: string;
    count?: number;
    active: boolean;
    onClick: () => void;
  }): HTMLElement {
    const children: (HTMLElement | string)[] = [opts.label];
    if (opts.count != null) children.push(el('span', { class: 'chip-count' }, String(opts.count)));
    const disabled = opts.count === 0 && !opts.active;
    const classNames = ['filter-chip'];
    if (opts.active) classNames.push('active');
    if (disabled) classNames.push('is-disabled');
    const attrs: Record<string, string> = { type: 'button', class: classNames.join(' ') };
    if (disabled) {
      attrs['aria-disabled'] = 'true';
      attrs['disabled'] = '';
      attrs['tabindex'] = '-1';
    }
    const btn = el('button', attrs, children);
    if (!disabled) btn.addEventListener('click', opts.onClick);
    return btn;
  }

  function topCategories(reviews: LatestReviewEntry[], n = 8): Array<{ cat: string; count: number }> {
    const counts = new Map<string, number>();
    for (const r of reviews) {
      for (const c of r.arxiv_categories ?? []) counts.set(c, (counts.get(c) ?? 0) + 1);
    }
    return [...counts.entries()]
      .sort(([, a], [, b]) => b - a)
      .slice(0, n)
      .map(([cat, count]) => ({ cat, count }));
  }

  function applyFilter(reviews: LatestReviewEntry[]): LatestReviewEntry[] {
    const quadrant = QUADRANTS.find((q) => q.key === state.quadrant) ?? QUADRANTS[0];
    return reviews.filter((r) => {
      if (!quadrant.match(r)) return false;
      if (state.categories.size > 0) {
        const cats = r.arxiv_categories ?? [];
        if (!cats.some((c) => state.categories.has(c))) return false;
      }
      return true;
    });
  }

  function applySort(arr: LatestReviewEntry[]): LatestReviewEntry[] {
    // Always rank by expected impact desc; tie-break by recency.
    return arr.slice().sort((a, b) => {
      const ea = expectedImpact(a);
      const eb = expectedImpact(b);
      if (ea !== eb) return eb - ea;
      const ta = Date.parse(a.updated_at || `${a.date}T00:00:00Z`);
      const tb = Date.parse(b.updated_at || `${b.date}T00:00:00Z`);
      return tb - ta;
    });
  }

  function rowChipsWrap(rowSelector: string): HTMLElement | null {
    const row = document.querySelector<HTMLElement>(rowSelector);
    return row?.querySelector<HTMLElement>('.filter-chips-wrap') ?? null;
  }

  function clearChildren(node: HTMLElement) {
    while (node.firstChild) node.removeChild(node.firstChild);
  }

  function renderChips(reviews: LatestReviewEntry[], onChange: () => void) {
    const quadWrap = rowChipsWrap('[data-filter="quadrant"]');
    const catsWrap = rowChipsWrap('[data-filter="categories"]');
    if (!quadWrap || !catsWrap) return;

    clearChildren(quadWrap);
    for (const q of QUADRANTS) {
      const count = reviews.filter(q.match).length;
      quadWrap.appendChild(chip({
        label: q.label,
        count,
        active: state.quadrant === q.key,
        onClick: () => {
          if (state.quadrant === q.key) return;
          state.quadrant = q.key;
          onChange();
        },
      }));
    }

    const cats = topCategories(reviews);
    clearChildren(catsWrap);
    if (cats.length === 0) {
      catsWrap.appendChild(el('span', { class: 'filter-hint' }, 'none yet'));
    } else {
      for (const { cat, count } of cats) {
        catsWrap.appendChild(chip({
          label: cat,
          count,
          active: state.categories.has(cat),
          onClick: () => {
            if (state.categories.has(cat)) state.categories.delete(cat);
            else state.categories.add(cat);
            onChange();
          },
        }));
      }
    }
  }

  (async () => {
    const listEl = document.getElementById('browse-list');
    const emptyEl = document.getElementById('browse-empty-state');
    const countEl = document.getElementById('browse-count');
    const resetBtn = document.getElementById('browse-reset');
    if (!listEl || !countEl) return;

    let data: { generated_at: string; reviews: LatestReviewEntry[] };
    try {
      data = await dataClient.getLatest();
    } catch (err) {
      mount(listEl, el('div', { class: 'state error' }, [
        el('strong', {}, 'Failed to load reviews'),
        el('span', {}, err instanceof Error ? err.message : 'Please try again.'),
      ]));
      return;
    }

    const reviews = data.reviews;
    const cards = new Map<string, HTMLElement>();
    reviews.forEach((review) => cards.set(review.id, buildFeedCard(review)));

    const snapshotLabel = `snapshot ${timeAgo(data.generated_at)}`;

    readStateFromUrl();

    function sync() {
      const filtered = applyFilter(reviews);
      const ordered = applySort(filtered);
      const nodes = ordered.map((r) => cards.get(r.id)).filter((n): n is HTMLElement => n != null);

      if (nodes.length === 0) {
        mount(listEl!);
        if (emptyEl) emptyEl.hidden = false;
      } else {
        if (emptyEl) emptyEl.hidden = true;
        mount(listEl!, ...nodes);
      }

      countEl!.textContent = `Showing ${nodes.length} of ${reviews.length} review${reviews.length === 1 ? '' : 's'} · ${snapshotLabel}`;
      writeStateToUrl();
    }

    renderChips(reviews, () => { sync(); renderChips(reviews, () => sync()); });

    resetBtn?.addEventListener('click', () => {
      resetState();
      renderChips(reviews, () => { sync(); renderChips(reviews, () => sync()); });
      sync();
    });

    sync();
  })();
</script>
