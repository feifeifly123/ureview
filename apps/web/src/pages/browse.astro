---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Browse reviews"
  description="Browse the recent OpenAgent.review queue with filters for response status, search, and recency."
  activeNav="browse"
>
  <div class="page-header page-header--browse">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span>Browse</span>
      </nav>
      <div class="page-header-grid">
        <div>
          <h1>Browse recent reviews</h1>
          <p class="subtitle">
            Scan the queue like an index page: filter by author response status, search titles and summaries,
            then jump into the thread that looks worth reading.
          </p>
        </div>
        <div class="page-header-aside" id="browse-header-aside" aria-live="polite"></div>
      </div>
    </div>
  </div>

  <div class="container browse-shell">
    <section class="browse-toolbar-card" aria-label="Browse controls">
      <div class="browse-toolbar-top">
        <label class="browse-search">
          <span class="sr-only">Search review queue</span>
          <input id="browse-search" type="search" placeholder="Search title or summary" />
        </label>

        <label class="browse-sort-label">
          <span>Sort</span>
          <select id="browse-sort">
            <option value="updated">Most active</option>
            <option value="newest">Newest</option>
            <option value="score">Highest score</option>
          </select>
        </label>

        <button type="button" class="btn-secondary btn-secondary--compact" id="browse-copy-link">
          Copy current view
        </button>
      </div>

      <div
        class="browse-status-tabs"
        role="tablist"
        aria-label="Filter browse view by status"
        id="browse-status-tabs"
      ></div>

      <div class="browse-toolbar-bottom">
        <div id="browse-results-count" class="browse-results-count">Loading…</div>
        <button type="button" class="browse-clear-filters" id="browse-clear-filters">Clear filters</button>
      </div>
    </section>

    <section class="browse-list" id="browse-list" aria-live="polite">
      <div class="state loading">
        <strong>Loading reviews…</strong>
      </div>
    </section>

    <div class="state empty" id="browse-empty-state" hidden>
      <strong>No reviews match this view</strong>
      <span>Clear the filters or try a broader search.</span>
    </div>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { formatDate, formatDateTime, formatScore } from '../lib/utils';
  import { latestLastActivity } from '../lib/latest';
  import type { LatestReviewEntry } from '../lib/types';

  type StatusFilter = 'all' | 'needs-response' | 'responded';
  type SortKey = 'updated' | 'newest' | 'score';

  function statusOf(review: LatestReviewEntry): 'responded' | 'needs-response' {
    return review.has_response ? 'responded' : 'needs-response';
  }

  function buildHeaderAside(count: number, generatedAt: string): HTMLElement[] {
    return [
      el('div', { class: 'count-chip' }, [el('strong', {}, String(count)), ' reviews in the current snapshot']),
      el('div', { class: 'page-header-meta' }, `Generated ${formatDateTime(generatedAt)}`),
    ];
  }

  function buildStatusTabs(
    counts: { all: number; 'needs-response': number; responded: number },
    current: StatusFilter
  ): HTMLElement[] {
    const items: Array<{ id: StatusFilter; label: string; count: number }> = [
      { id: 'all', label: 'All', count: counts.all },
      { id: 'needs-response', label: 'Needs response', count: counts['needs-response'] },
      { id: 'responded', label: 'Author responded', count: counts.responded },
    ];
    return items.map((item) => {
      const isActive = item.id === current;
      return el(
        'button',
        {
          class: isActive ? 'browse-status-tab active' : 'browse-status-tab',
          type: 'button',
          role: 'tab',
          'aria-selected': isActive ? 'true' : 'false',
          'data-status-filter': item.id,
        },
        [item.label, ' ', el('span', {}, String(item.count))]
      );
    });
  }

  function buildCard(review: LatestReviewEntry): HTMLElement {
    const chips: HTMLElement[] = [
      el('span', { class: 'topic-chip topic-chip--ai' }, 'AI review'),
      el(
        'span',
        {
          class: review.has_response
            ? 'topic-chip topic-chip--author'
            : 'topic-chip topic-chip--waiting',
        },
        review.has_response ? 'Author responded' : 'Needs response'
      ),
    ];
    if (review.hf_rank != null) {
      chips.push(el('span', { class: 'topic-chip topic-chip--ghost' }, `HF #${review.hf_rank}`));
    }
    if (review.has_response && (review.response_count ?? 0) > 1) {
      chips.push(el('span', { class: 'topic-chip topic-chip--discussion' }, 'Active discussion'));
    }

    const noteCount = (review.response_count ?? 0) + 1;

    return el(
      'article',
      {
        class: 'browse-card',
        'data-browse-card': 'true',
        'data-review-id': review.id,
        'data-status': statusOf(review),
        'data-title': review.title.toLowerCase(),
        'data-summary': review.summary.toLowerCase(),
      },
      [
        el('div', { class: 'browse-card-main' }, [
          el('div', { class: 'browse-card-top' }, [
            el('div', { class: 'browse-card-chips' }, chips),
            el(
              'div',
              { class: 'browse-card-updated' },
              `Last activity ${formatDateTime(latestLastActivity(review))}`
            ),
          ]),
          el(
            'a',
            { class: 'browse-card-title', href: `/review/?id=${encodeURIComponent(review.id)}` },
            review.title
          ),
          el('p', { class: 'browse-card-summary' }, review.summary),
          el('div', { class: 'browse-card-footer' }, [
            el('span', {}, `Reviewed ${formatDate(review.date)}`),
            el(
              'a',
              { href: `/review/?id=${encodeURIComponent(review.id)}` },
              'Open thread \u2192'
            ),
          ]),
        ]),
        el('aside', { class: 'browse-card-aside' }, [
          el('dl', { class: 'browse-card-metrics' }, [
            el('div', {}, [el('dt', {}, 'Score'), el('dd', {}, `${formatScore(review.score)}/10`)]),
            el('div', {}, [el('dt', {}, 'Conf.'), el('dd', {}, `${review.confidence ?? 0}/5`)]),
            el('div', {}, [el('dt', {}, 'Notes'), el('dd', {}, String(noteCount))]),
          ]),
        ]),
      ]
    );
  }

  (async () => {
    const asideEl = document.getElementById('browse-header-aside');
    const tabsEl = document.getElementById('browse-status-tabs');
    const listEl = document.getElementById('browse-list');
    const emptyEl = document.getElementById('browse-empty-state');
    const searchInput = document.getElementById('browse-search') as HTMLInputElement | null;
    const sortSelect = document.getElementById('browse-sort') as HTMLSelectElement | null;
    const resultsCount = document.getElementById('browse-results-count');
    const clearFilters = document.getElementById('browse-clear-filters');
    const copyLinkButton = document.getElementById('browse-copy-link') as HTMLButtonElement | null;

    if (!asideEl || !tabsEl || !listEl || !searchInput || !sortSelect || !resultsCount) return;

    let data: { generated_at: string; reviews: LatestReviewEntry[] };
    try {
      data = await dataClient.getLatest();
    } catch (err) {
      mount(listEl, el('div', { class: 'state error' }, [
        el('strong', {}, 'Failed to load reviews'),
        el('span', {}, err instanceof Error ? err.message : 'Please try again.'),
      ]));
      return;
    }

    const reviews = data.reviews;
    const cards = new Map<string, HTMLElement>();
    reviews.forEach((review) => cards.set(review.id, buildCard(review)));

    const counts = {
      all: reviews.length,
      'needs-response': reviews.filter((r) => !r.has_response).length,
      responded: reviews.filter((r) => r.has_response).length,
    };

    mount(asideEl, ...buildHeaderAside(reviews.length, data.generated_at));

    let currentStatus: StatusFilter = 'all';

    function renderTabs() {
      mount(tabsEl, ...buildStatusTabs(counts, currentStatus));
      tabsEl.querySelectorAll<HTMLButtonElement>('[data-status-filter]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const next = (btn.dataset.statusFilter ?? 'all') as StatusFilter;
          if (next === currentStatus) return;
          currentStatus = next;
          renderTabs();
          sync();
        });
      });
    }

    function updateUrl(q: string) {
      const url = new URL(window.location.href);
      if (currentStatus !== 'all') url.searchParams.set('status', currentStatus);
      else url.searchParams.delete('status');
      if (sortSelect?.value && sortSelect.value !== 'updated') url.searchParams.set('sort', sortSelect.value);
      else url.searchParams.delete('sort');
      if (q) url.searchParams.set('q', q);
      else url.searchParams.delete('q');
      history.replaceState({}, '', url);
    }

    function sortedReviews(source: LatestReviewEntry[]): LatestReviewEntry[] {
      const sortKey = (sortSelect?.value as SortKey) ?? 'updated';
      return source.slice().sort((a, b) => {
        if (sortKey === 'score') return b.score - a.score;
        if (sortKey === 'newest') return Date.parse(b.date) - Date.parse(a.date);
        return Date.parse(latestLastActivity(b)) - Date.parse(latestLastActivity(a));
      });
    }

    function sync() {
      const q = searchInput?.value.trim().toLowerCase() ?? '';
      const filtered = reviews.filter((review) => {
        const matchesStatus = currentStatus === 'all' || statusOf(review) === currentStatus;
        const blob = `${review.title.toLowerCase()} ${review.summary.toLowerCase()}`;
        const matchesSearch = q.length === 0 || blob.includes(q);
        return matchesStatus && matchesSearch;
      });

      const orderedNodes = sortedReviews(filtered)
        .map((r) => cards.get(r.id))
        .filter((n): n is HTMLElement => n != null);

      if (orderedNodes.length === 0) {
        mount(listEl);
        if (emptyEl) emptyEl.hidden = false;
      } else {
        if (emptyEl) emptyEl.hidden = true;
        mount(listEl, ...orderedNodes);
      }

      resultsCount.textContent = `Showing ${filtered.length} result${filtered.length === 1 ? '' : 's'}`;
      updateUrl(q);
    }

    // Wire up controls
    const params = new URLSearchParams(window.location.search);
    const initialStatus = params.get('status');
    const initialSort = params.get('sort');
    const initialQuery = params.get('q');
    if (initialQuery) searchInput.value = initialQuery;
    if (initialSort && ['updated', 'newest', 'score'].includes(initialSort)) {
      sortSelect.value = initialSort;
    }
    if (initialStatus === 'needs-response' || initialStatus === 'responded') {
      currentStatus = initialStatus;
    }

    searchInput.addEventListener('input', sync);
    sortSelect.addEventListener('change', sync);
    clearFilters?.addEventListener('click', () => {
      searchInput.value = '';
      sortSelect.value = 'updated';
      currentStatus = 'all';
      renderTabs();
      sync();
    });

    copyLinkButton?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyLinkButton.textContent = 'Copied';
        setTimeout(() => {
          copyLinkButton.textContent = 'Copy current view';
        }, 1200);
      } catch {
        copyLinkButton.textContent = 'Copy failed';
        setTimeout(() => {
          copyLinkButton.textContent = 'Copy current view';
        }, 1200);
      }
    });

    renderTabs();
    sync();
  })();
</script>
