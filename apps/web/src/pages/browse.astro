---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Browse reviews"
  description="Browse recent OpenAgent.review papers — search titles and abstracts, sort by date or trending rank."
  activeNav="browse"
>
  <div class="page-header page-header--browse">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span>Browse</span>
      </nav>
      <div class="page-header-grid">
        <div>
          <h1>Browse recent reviews</h1>
          <p class="subtitle">
            Search by title or abstract, sort by date or trending rank, then jump into the thread.
          </p>
        </div>
        <div class="page-header-aside" id="browse-header-aside" aria-live="polite"></div>
      </div>
    </div>
  </div>

  <div class="container browse-shell">
    <section class="browse-toolbar-card" aria-label="Browse controls">
      <div class="browse-toolbar-top">
        <label class="browse-search">
          <span class="sr-only">Search review queue</span>
          <input id="browse-search" type="search" placeholder="Search title or abstract" />
        </label>

        <label class="browse-sort-label">
          <span>Sort</span>
          <select id="browse-sort">
            <option value="newest">Newest</option>
            <option value="hf">HF rank</option>
          </select>
        </label>

        <button type="button" class="btn-secondary btn-secondary--compact" id="browse-copy-link">
          Copy current view
        </button>
      </div>

      <div class="browse-toolbar-bottom">
        <div id="browse-results-count" class="browse-results-count">Loading…</div>
        <button type="button" class="browse-clear-filters" id="browse-clear-filters">Clear filters</button>
      </div>
    </section>

    <section class="browse-list" id="browse-list" aria-live="polite">
      <div class="state loading">
        <strong>Loading reviews…</strong>
      </div>
    </section>

    <div class="state empty" id="browse-empty-state" hidden>
      <strong>No reviews match this view</strong>
      <span>Clear the search or try a different query.</span>
    </div>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { formatDate, formatDateTime } from '../lib/utils';
  import type { LatestReviewEntry } from '../lib/types';

  type SortKey = 'newest' | 'hf';

  function buildHeaderAside(count: number, generatedAt: string): HTMLElement[] {
    return [
      el('div', { class: 'count-chip' }, [
        el('strong', {}, String(count)),
        ` review${count === 1 ? '' : 's'} in the current snapshot`,
      ]),
      el('div', { class: 'page-header-meta' }, `Generated ${formatDateTime(generatedAt)}`),
    ];
  }

  function buildCard(review: LatestReviewEntry): HTMLElement {
    const chips: HTMLElement[] = [el('span', { class: 'topic-chip topic-chip--ai' }, 'AI review')];
    if (review.hf_rank != null) {
      chips.push(el('span', { class: 'topic-chip topic-chip--ghost' }, `HF #${review.hf_rank}`));
    }

    return el(
      'article',
      {
        class: 'browse-card',
        'data-browse-card': 'true',
        'data-review-id': review.id,
        'data-title': review.title.toLowerCase(),
        'data-summary': review.abstract.toLowerCase(),
      },
      [
        el('div', { class: 'browse-card-main' }, [
          el('div', { class: 'browse-card-top' }, [
            el('div', { class: 'browse-card-chips' }, chips),
            el('div', { class: 'browse-card-updated' }, `Reviewed ${formatDate(review.date)}`),
          ]),
          el(
            'a',
            { class: 'browse-card-title', href: `/review/?id=${encodeURIComponent(review.id)}` },
            review.title
          ),
          el('p', { class: 'browse-card-summary' }, review.abstract),
          el('div', { class: 'browse-card-footer' }, [
            el('span', {}, 'From arXiv'),
            el(
              'a',
              { href: `/review/?id=${encodeURIComponent(review.id)}` },
              'Open thread \u2192'
            ),
          ]),
        ]),
      ]
    );
  }

  (async () => {
    const asideEl = document.getElementById('browse-header-aside');
    const listEl = document.getElementById('browse-list');
    const emptyEl = document.getElementById('browse-empty-state');
    const searchInput = document.getElementById('browse-search') as HTMLInputElement | null;
    const sortSelect = document.getElementById('browse-sort') as HTMLSelectElement | null;
    const resultsCount = document.getElementById('browse-results-count');
    const clearFilters = document.getElementById('browse-clear-filters');
    const copyLinkButton = document.getElementById('browse-copy-link') as HTMLButtonElement | null;

    if (!asideEl || !listEl || !searchInput || !sortSelect || !resultsCount) return;

    let data: { generated_at: string; reviews: LatestReviewEntry[] };
    try {
      data = await dataClient.getLatest();
    } catch (err) {
      mount(listEl, el('div', { class: 'state error' }, [
        el('strong', {}, 'Failed to load reviews'),
        el('span', {}, err instanceof Error ? err.message : 'Please try again.'),
      ]));
      return;
    }

    const reviews = data.reviews;
    const cards = new Map<string, HTMLElement>();
    reviews.forEach((review) => cards.set(review.id, buildCard(review)));

    mount(asideEl, ...buildHeaderAside(reviews.length, data.generated_at));

    function updateUrl(q: string) {
      const url = new URL(window.location.href);
      if (sortSelect?.value && sortSelect.value !== 'newest') url.searchParams.set('sort', sortSelect.value);
      else url.searchParams.delete('sort');
      if (q) url.searchParams.set('q', q);
      else url.searchParams.delete('q');
      history.replaceState({}, '', url);
    }

    function sortedReviews(source: LatestReviewEntry[]): LatestReviewEntry[] {
      const sortKey = (sortSelect?.value as SortKey) ?? 'newest';
      return source.slice().sort((a, b) => {
        if (sortKey === 'hf') return (a.hf_rank ?? 10 ** 9) - (b.hf_rank ?? 10 ** 9);
        return Date.parse(b.date) - Date.parse(a.date);
      });
    }

    function sync() {
      const q = searchInput?.value.trim().toLowerCase() ?? '';
      const filtered = reviews.filter((review) => {
        const blob = `${review.title.toLowerCase()} ${review.abstract.toLowerCase()}`;
        return q.length === 0 || blob.includes(q);
      });

      const orderedNodes = sortedReviews(filtered)
        .map((r) => cards.get(r.id))
        .filter((n): n is HTMLElement => n != null);

      if (orderedNodes.length === 0) {
        mount(listEl);
        if (emptyEl) emptyEl.hidden = false;
      } else {
        if (emptyEl) emptyEl.hidden = true;
        mount(listEl, ...orderedNodes);
      }

      resultsCount.textContent = `Showing ${filtered.length} result${filtered.length === 1 ? '' : 's'}`;
      updateUrl(q);
    }

    const params = new URLSearchParams(window.location.search);
    const initialSort = params.get('sort');
    const initialQuery = params.get('q');
    if (initialQuery) searchInput.value = initialQuery;
    if (initialSort && ['newest', 'hf'].includes(initialSort)) {
      sortSelect.value = initialSort;
    }

    searchInput.addEventListener('input', sync);
    sortSelect.addEventListener('change', sync);
    clearFilters?.addEventListener('click', () => {
      searchInput.value = '';
      sortSelect.value = 'newest';
      sync();
    });

    copyLinkButton?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyLinkButton.textContent = 'Copied';
        setTimeout(() => {
          copyLinkButton.textContent = 'Copy current view';
        }, 1200);
      } catch {
        copyLinkButton.textContent = 'Copy failed';
        setTimeout(() => {
          copyLinkButton.textContent = 'Copy current view';
        }, 1200);
      }
    });

    sync();
  })();
</script>
