---
import Layout from '../components/Layout.astro';
---

<Layout
  title="OpenAgent.review"
  description="Structured AI reviews of trending arXiv papers — conference-style ratings alongside the original abstract."
  activeNav="home"
>
  <section class="hero hero--product">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Machine review feed</span>
        <h1 class="hero-heading hero-heading--left">
          Structured AI reviews for trending papers.
        </h1>
        <p class="hero-subtitle hero-subtitle--left">
          Each paper gets a conference-style review — summary, four dimension ratings, key questions — generated by a language model on its arXiv PDF.
        </p>
        <div class="hero-actions">
          <a href="/browse/" class="btn-cta">Browse recent reviews</a>
        </div>
        <p class="hero-note hero-note--inline">
          Machine-generated first-pass review, not peer review.
        </p>
      </div>
      <div id="home-hero-preview-slot" aria-live="polite"></div>
    </div>
  </section>

  <section id="home-counters" aria-live="polite"></section>

  <div class="container home-shell" id="activity">
    <div class="home-main-column">
      <div class="section-heading-row">
        <div>
          <span class="section-eyebrow">Index</span>
          <h2 class="section-heading section-heading--tight">Recent reviews</h2>
          <p class="section-copy">
            Each card opens a structured review page showing dimension ratings, the arXiv abstract, and the raw agent output.
          </p>
        </div>
        <a href="/browse/" class="section-link">Open full browse view</a>
      </div>

      <div class="home-card-list" id="home-card-list">
        <div class="state loading">
          <strong>Loading reviews…</strong>
        </div>
      </div>

      <div class="state empty" id="home-empty-state" hidden>
        <strong>No reviews to show.</strong>
        <span>Fresh papers land daily from the HF trending feed.</span>
      </div>
    </div>

    <aside class="home-sidebar">
      <section class="sidebar-box sidebar-box--guide" id="how-it-works">
        <span class="sidebar-kicker">How to read this site</span>
        <h3 class="sidebar-heading">Same review, three layers.</h3>
        <ul class="sidebar-steps sidebar-steps--calm sidebar-steps--flat">
          <li>
            <strong>Speedread</strong>
            <span>One-line verdict, recommendation, and agent confidence at the top.</span>
          </li>
          <li>
            <strong>Four dimensions</strong>
            <span>Soundness, presentation, significance, originality — each with a short note, never averaged.</span>
          </li>
          <li>
            <strong>Raw view</strong>
            <span>The arXiv abstract and the agent's own prose, unmodified, for audit.</span>
          </li>
        </ul>
      </section>
    </aside>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { formatDate } from '../lib/utils';
  import { buildFeedCard, leaningLabel, confidenceBand } from '../lib/feed-card';
  import type { LatestReviewEntry } from '../lib/types';

  function buildHeroPreview(sample: LatestReviewEntry): HTMLElement {
    const chips: HTMLElement[] = [el('span', { class: 'topic-chip topic-chip--ai' }, 'AI review')];
    if (sample.hf_rank != null) {
      chips.push(el('span', { class: 'topic-chip topic-chip--ghost' }, `HF #${sample.hf_rank}`));
    }
    if (sample.arxiv_categories && sample.arxiv_categories.length > 0) {
      chips.push(el('span', { class: 'topic-chip topic-chip--ghost' }, sample.arxiv_categories[0]));
    }
    if (sample.ethics_flag) {
      chips.push(el('span', { class: 'topic-chip topic-chip--warning' }, '\u26A0 Ethics flag'));
    }

    const metaBits: HTMLElement[] = [];
    if (sample.verdict_leaning) {
      metaBits.push(
        el(
          'span',
          { class: `leaning-pill leaning-pill--${sample.verdict_leaning}` },
          leaningLabel(sample.verdict_leaning)
        )
      );
    }
    if (sample.confidence) {
      metaBits.push(
        el('span', { class: 'home-card-meta-dot' }, [
          el('span', { class: 'home-card-meta-sep' }, '\u00b7'),
          `Confidence ${confidenceBand(sample.confidence)}`,
        ])
      );
    }

    return el('aside', { class: 'hero-preview-card', 'aria-label': 'Featured review preview' }, [
      el('span', { class: 'hero-featured-label' }, 'Featured review'),
      el('div', { class: 'hero-preview-top' }, chips),
      el('h2', { class: 'hero-preview-title' }, sample.title),
      sample.why_read
        ? el('p', { class: 'hero-preview-summary' }, sample.why_read)
        : el('p', { class: 'hero-preview-summary' }, sample.abstract),
      el('div', { class: 'home-card-meta-row hero-preview-meta' }, metaBits),
      el('div', { class: 'hero-preview-footer' }, [
        el('span', {}, formatDate(sample.date)),
        el(
          'a',
          { href: `/review/?id=${encodeURIComponent(sample.id)}` },
          'Open review \u2192'
        ),
      ]),
    ]);
  }

  function buildTrustStrip(totalCount: number): HTMLElement {
    return el('div', { class: 'container' }, [
      el(
        'p',
        { class: 'trust-strip-text' },
        `${totalCount} paper${totalCount === 1 ? '' : 's'} reviewed \u00b7 Source: HF Daily Papers \u00b7 Agent-generated structured reviews`
      ),
    ]);
  }

  (async () => {
    const listEl = document.getElementById('home-card-list');
    const emptyEl = document.getElementById('home-empty-state');
    const countersEl = document.getElementById('home-counters');
    const heroSlot = document.getElementById('home-hero-preview-slot');
    if (!listEl || !countersEl || !heroSlot) return;

    let data: { generated_at: string; reviews: LatestReviewEntry[] };
    try {
      data = await dataClient.getLatest();
    } catch (err) {
      mount(listEl, el('div', { class: 'state error' }, [
        el('strong', {}, 'Failed to load reviews'),
        el('span', {}, err instanceof Error ? err.message : 'Please try again.'),
      ]));
      return;
    }

    const reviews = data.reviews;
    const sample = reviews[0];

    if (sample) mount(heroSlot, buildHeroPreview(sample));

    countersEl.className = 'home-trust-strip';
    mount(countersEl, buildTrustStrip(reviews.length));

    if (reviews.length === 0) {
      mount(listEl);
      if (emptyEl) emptyEl.hidden = false;
      return;
    }
    if (emptyEl) emptyEl.hidden = true;
    mount(listEl, ...reviews.map((review) => buildFeedCard(review)));
  })();
</script>
