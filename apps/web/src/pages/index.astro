---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Ureview.ai"
  description="AI reviews for new papers, with invited author responses."
  activeNav="home"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-heading">
        AI reviews for new papers, with invited author responses.
      </h1>
      <p class="hero-subtitle">
        A public forum for AI-generated paper reviews, final author responses,
        and public review threads.
      </p>
      <a href="#activity" class="btn-cta">Browse recent reviews</a>
      <p class="hero-note">
        Invited authors can respond through a private link sent by email.
      </p>
    </div>
  </section>

  <!-- Filter Tabs -->
  <div class="container" id="activity">
    <div class="filter-tabs" role="tablist" aria-label="Filter reviews">
      <button class="filter-tab active" role="tab" aria-selected="true" data-filter="all">All</button>
      <button class="filter-tab" role="tab" aria-selected="false" data-filter="needs-response">Needs Response</button>
      <button class="filter-tab" role="tab" aria-selected="false" data-filter="responded">Author Responded</button>
      <button class="filter-tab" role="tab" aria-selected="false" data-filter="recent">Recently Updated</button>
    </div>
  </div>

  <!-- Two-column layout -->
  <div class="container">
    <div class="homepage-main">
      <!-- Left: Recent Activity -->
      <div class="activity-column">
        <h2 class="section-heading">Recent Activity</h2>
        <div id="activity-list">
          <div class="paper-card skeleton-card">
            <div class="skeleton-line lg"></div>
            <div class="skeleton-line"></div>
            <div class="skeleton-line sm"></div>
          </div>
          <div class="paper-card skeleton-card">
            <div class="skeleton-line lg"></div>
            <div class="skeleton-line"></div>
            <div class="skeleton-line sm"></div>
          </div>
        </div>
      </div>

      <!-- Right: Sidebar -->
      <aside class="sidebar-column">
        <div class="sidebar-box" id="how-it-works">
          <h3 class="sidebar-heading">How it works</h3>
          <ol class="sidebar-steps">
            <li>
              <strong>New papers are reviewed by AI</strong>
              <span>Trending papers receive an automated review with scores and analysis.</span>
            </li>
            <li>
              <strong>Authors receive a private response link</strong>
              <span>Paper authors are invited via email to submit a response.</span>
            </li>
            <li>
              <strong>Authors submit a final response</strong>
              <span>Authors can review the AI feedback and publish their reply.</span>
            </li>
            <li>
              <strong>The public can read both sides</strong>
              <span>Reviews and responses are published together as a public thread.</span>
            </li>
          </ol>
        </div>

        <div class="sidebar-box">
          <h3 class="sidebar-heading">Why trust Ureview.ai</h3>
          <p class="sidebar-text">
            AI-generated scores are not peer review. They serve as a rough
            triage filter. Author responses provide crucial context that
            AI alone cannot capture. Final public threads give readers both
            perspectives.
          </p>
        </div>

        <div class="sidebar-box">
          <h3 class="sidebar-heading">Recent author responses</h3>
          <div id="recent-responses"></div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { paperCard, stateView } from '../lib/render';
  import { formatScore } from '../lib/utils';
  import type { LatestReviewEntry } from '../lib/types';

  type FilterKey = 'all' | 'needs-response' | 'responded' | 'recent';

  function filterReviews(arr: LatestReviewEntry[], key: FilterKey): LatestReviewEntry[] {
    switch (key) {
      case 'all':
        return arr;
      case 'needs-response':
        return arr.filter((r) => !r.has_response);
      case 'responded':
        return arr.filter((r) => r.has_response === true);
      case 'recent':
        return arr.slice().sort((a, b) => b.date.localeCompare(a.date));
    }
  }

  function renderCards(container: Element, reviews: LatestReviewEntry[]) {
    if (reviews.length === 0) {
      mount(container, stateView('empty', 'No reviews match', 'Try a different filter.'));
      return;
    }
    mount(container, ...reviews.map((r) => paperCard(r)));
  }

  function renderResponsesSidebar(container: Element, reviews: LatestReviewEntry[]) {
    const responded = reviews.filter((r) => r.has_response === true).slice(0, 4);
    if (responded.length === 0) {
      mount(container, el('p', { class: 'sidebar-text' }, 'No author responses yet.'));
      return;
    }
    mount(
      container,
      ...responded.map((r) =>
        el('a', { class: 'response-compact', href: `/review/?id=${encodeURIComponent(r.id)}` }, [
          el('span', { class: 'response-compact-title' }, r.title),
          el('span', { class: 'response-compact-score' }, formatScore(r.score)),
        ])
      )
    );
  }

  async function main() {
    const listContainer = document.getElementById('activity-list')!;
    const responsesContainer = document.getElementById('recent-responses')!;
    const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');

    let data: LatestReviewEntry[] = [];
    try {
      const res = await dataClient.getLatest();
      data = res.reviews;
    } catch (e) {
      mount(
        listContainer,
        stateView('error', 'Failed to load', e instanceof Error ? e.message : String(e))
      );
      return;
    }

    let currentFilter: FilterKey = 'all';
    const update = () => renderCards(listContainer, filterReviews(data, currentFilter));
    update();
    renderResponsesSidebar(responsesContainer, data);

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        currentFilter = (tab.dataset.filter ?? 'all') as FilterKey;
        update();
      });
    });
  }

  main();
</script>
