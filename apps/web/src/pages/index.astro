---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Ureview"
  description="AI proof reviews of arxiv math papers — one structured machine reading per paper."
  activeNav="home"
>
  <div class="container">
    <section class="page-intro">
      <span class="page-intro-eyebrow">The Triage Desk · BETA</span>
      <h1 class="page-intro-title">Arxiv math, ranked by expected impact.</h1>
      <p class="page-intro-lede">
        Every paper gets two numbers: <strong>impact if the proof is correct</strong>
        and <strong>probability the proof is correct</strong>. The feed is ordered
        by their product — a high-impact paper with a shaky proof and a modest
        paper with an airtight one can meet on the same scale. Single-pass
        machine reading. Not peer review.
      </p>
    </section>

    <div id="home-hero-slot" aria-live="polite">
      <section class="hero-featured hero-featured--skel" aria-label="Loading featured filing">
        <div class="hero-featured-inner">
          <div class="hero-kicker">
            <span class="skel-block skel-line-xs" style="width:18%"></span>
            <span class="skel-block skel-line-xs" style="width:22%"></span>
            <span class="skel-block skel-line-xs" style="width:14%"></span>
          </div>
          <div>
            <div class="skel-block skel-title-big"></div>
            <div class="skel-block skel-line-md" style="margin-top:14px"></div>
            <div class="skel-block skel-line-sm" style="margin-top:6px"></div>
          </div>
        </div>
      </section>
    </div>

    <section class="stack">
      <header class="stack-header">
        <div>
          <span class="stack-eyebrow">The stack</span>
          <h2 class="stack-title">Recent filings</h2>
        </div>
        <div class="stack-aside">
          <a href="/browse/">Full browse view →</a>
        </div>
      </header>

      <div class="entry-list" id="home-list">
        {Array.from({ length: 5 }).map(() => (
          <div class="entry entry--skel" aria-hidden="true">
            <span class="entry-kicker"><span class="skel-block skel-line-xs"></span></span>
            <span class="entry-title"><span class="skel-block skel-title"></span></span>
            <div class="entry-footer"><span class="skel-block skel-line-sm" style="width:30%"></span></div>
          </div>
        ))}
      </div>

      <div class="state empty" id="home-empty" hidden>
        <strong>No reviews yet</strong>
        <span>Reviews are filed one at a time as math papers come in.</span>
      </div>
    </section>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { authorsDetailed } from '../lib/format';
  import { scheduleTypeset } from '../lib/latex';
  import { buildFeedCard } from '../lib/feed-card';
  import { expectedImpact, categoryName } from '../lib/types';
  import type { LatestReviewEntry } from '../lib/types';

  function buildFeaturedEntry(entry: LatestReviewEntry): HTMLElement {
    const e = expectedImpact(entry);
    const kickerBits: HTMLElement[] = [];
    kickerBits.push(el('span', { class: 'issue-no' }, `TOP OF FEED · E ${e.toFixed(1)}`));
    kickerBits.push(el('span', { class: 'kicker-sep' }, '·'));
    kickerBits.push(el('span', {}, entry.id));
    const cats = entry.arxiv_categories ?? [];
    if (cats.length > 0) {
      kickerBits.push(el('span', { class: 'kicker-sep' }, '·'));
      kickerBits.push(el('span', { title: categoryName(cats[0]) }, cats[0]));
    }
    const kicker = el('div', { class: 'hero-kicker' }, kickerBits);

    const title = el('h2', { class: 'hero-title' }, [
      el('a', { href: `/review/${entry.id}/` }, entry.title),
    ]);

    const authors = authorsDetailed(entry.authors);
    const authorsEl = authors ? el('p', { class: 'hero-authors' }, authors) : null;

    const scoreRow = el('p', { class: 'hero-scores' }, [
      el('span', { class: `hero-score hero-score--tier-${entry.impact_if_true}` }, [el('em', {}, 'Impact '), el('strong', {}, entry.impact_if_true)]),
      el('span', { class: 'hero-score-sep' }, ' × '),
      el('span', { class: `hero-score hero-score--tier-${entry.proof_correctness}` }, [el('em', {}, 'Correctness '), el('strong', {}, entry.proof_correctness)]),
      el('span', { class: 'hero-score-sep' }, ' = '),
      el('span', { class: 'hero-score hero-score--strong' }, [el('strong', {}, e.toFixed(1))]),
    ]);

    const lede = entry.review_lede
      ? el('p', { class: 'hero-lede', 'data-typeset': 'true' }, entry.review_lede)
      : null;

    const foot = el('div', { class: 'hero-foot' }, [
      el('span', {}, 'Ranked by E[impact]. Single-pass machine reading.'),
      el('a', { href: `/review/${entry.id}/` }, 'Open the full review →'),
    ]);

    return el('section', { class: 'hero-featured', 'aria-label': 'Featured review' }, [
      el(
        'div',
        { class: 'hero-featured-inner' },
        [kicker, el('div', {}, [title, authorsEl, scoreRow, lede].filter((n): n is HTMLElement => n != null)), foot],
      ),
    ]);
  }

  (async () => {
    const heroSlot = document.getElementById('home-hero-slot');
    const listEl = document.getElementById('home-list');
    const emptyEl = document.getElementById('home-empty');
    if (!heroSlot || !listEl) return;

    let data: { generated_at: string; reviews: LatestReviewEntry[] };
    try {
      data = await dataClient.getLatest();
    } catch (err) {
      mount(heroSlot);
      mount(listEl, el('div', { class: 'state error' }, [
        el('strong', {}, 'Failed to load reviews'),
        el('span', {}, err instanceof Error ? err.message : 'Please try again.'),
      ]));
      return;
    }

    const reviews = data.reviews;
    const featured = reviews[0];

    if (featured) {
      mount(heroSlot, buildFeaturedEntry(featured));
    } else {
      mount(heroSlot);
    }

    const rest = reviews.slice(1);
    if (rest.length === 0) {
      mount(listEl);
      if (emptyEl && reviews.length === 0) emptyEl.hidden = false;
      // typeset hero lede if any
      if (heroSlot) await scheduleTypeset(heroSlot);
      return;
    }
    if (emptyEl) emptyEl.hidden = true;
    mount(listEl, ...rest.map((r) => buildFeedCard(r)));
    await scheduleTypeset(heroSlot);
    await scheduleTypeset(listEl);
  })();
</script>
