---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Ureview"
  description="AI proof reviews of arxiv math papers — one structured machine reading per paper."
  activeNav="home"
>
  <div class="container">
    <section class="page-intro">
      <span class="page-intro-eyebrow">The Gazette · Machine Reading Desk</span>
      <h1 class="page-intro-title">AI proof reviews of arxiv math papers.</h1>
      <p class="page-intro-lede">
        For every paper, one long-form machine reading of the proof —
        what it shows, where the argument leans, what to watch for.
        The metadata is straight from arxiv; the review is the only
        thing we file.
      </p>
    </section>

    <aside class="beta-strip" role="note" aria-label="Beta notice">
      <span class="beta-tag">BETA</span>
      <span class="beta-text">
        First-pass machine readings of <a href="https://arxiv.org/archive/math" target="_blank" rel="noopener">arxiv math</a> papers. Not peer review.
      </span>
    </aside>

    <div id="home-hero-slot" aria-live="polite">
      <section class="hero-featured hero-featured--skel" aria-label="Loading featured filing">
        <div class="hero-featured-inner">
          <div class="hero-kicker">
            <span class="skel-block skel-line-xs" style="width:18%"></span>
            <span class="skel-block skel-line-xs" style="width:22%"></span>
            <span class="skel-block skel-line-xs" style="width:14%"></span>
          </div>
          <div>
            <div class="skel-block skel-title-big"></div>
            <div class="skel-block skel-line-md" style="margin-top:14px"></div>
            <div class="skel-block skel-line-sm" style="margin-top:6px"></div>
          </div>
        </div>
      </section>
    </div>

    <div id="home-trust-slot" class="trust-strip" aria-live="polite" hidden></div>

    <section class="stack">
      <header class="stack-header">
        <div>
          <span class="stack-eyebrow">The stack</span>
          <h2 class="stack-title">Recent filings</h2>
        </div>
        <div class="stack-aside">
          <a href="/browse/">Full browse view →</a>
        </div>
      </header>

      <div class="entry-list" id="home-list">
        {Array.from({ length: 5 }).map(() => (
          <div class="entry entry--skel" aria-hidden="true">
            <span class="entry-kicker"><span class="skel-block skel-line-xs"></span></span>
            <span class="entry-title"><span class="skel-block skel-title"></span></span>
            <div class="entry-footer"><span class="skel-block skel-line-sm" style="width:30%"></span></div>
          </div>
        ))}
      </div>

      <div class="state empty" id="home-empty" hidden>
        <strong>No reviews yet</strong>
        <span>Reviews are filed one at a time as math papers come in.</span>
      </div>
    </section>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { formatDate } from '../lib/utils';
  import { buildFeedCard } from '../lib/feed-card';
  import type { LatestReviewEntry } from '../lib/types';

  function authorsLine(authors: string[]): string {
    if (!authors || authors.length === 0) return '';
    if (authors.length <= 3) return authors.join(', ');
    return `${authors.slice(0, 3).join(', ')}, et al. (${authors.length - 3} more)`;
  }

  function buildFeaturedEntry(entry: LatestReviewEntry, total: number): HTMLElement {
    const kickerBits: HTMLElement[] = [];
    kickerBits.push(el('span', { class: 'issue-no' }, `№ ${String(total).padStart(3, '0')}`));
    kickerBits.push(el('span', { class: 'kicker-sep' }, '·'));
    kickerBits.push(el('span', {}, formatDate(entry.date)));
    kickerBits.push(el('span', { class: 'kicker-sep' }, '·'));
    kickerBits.push(el('span', {}, entry.id));
    const cats = entry.arxiv_categories ?? [];
    if (cats.length > 0) {
      kickerBits.push(el('span', { class: 'kicker-sep' }, '·'));
      kickerBits.push(el('span', {}, cats[0]));
    }
    const kicker = el('div', { class: 'hero-kicker' }, kickerBits);

    const title = el('h2', { class: 'hero-title' }, [
      el('a', { href: `/review/?id=${encodeURIComponent(entry.id)}` }, entry.title),
    ]);

    const authors = authorsLine(entry.authors ?? []);
    const authorsEl = authors ? el('p', { class: 'hero-authors' }, authors) : null;

    const lede = entry.review_lede
      ? el('p', { class: 'hero-lede', 'data-typeset': 'true' }, entry.review_lede)
      : null;

    const foot = el('div', { class: 'hero-foot' }, [
      el('span', {}, 'Machine-generated proof reading · Not peer review'),
      el('a', { href: `/review/?id=${encodeURIComponent(entry.id)}` }, 'Open the full review →'),
    ]);

    return el('section', { class: 'hero-featured', 'aria-label': 'Featured review' }, [
      el(
        'div',
        { class: 'hero-featured-inner' },
        [kicker, el('div', {}, [title, authorsEl, lede].filter((n): n is HTMLElement => n != null)), foot],
      ),
    ]);
  }

  function buildTrustStrip(total: number): HTMLElement {
    return el('p', { class: 'trust-strip-text' }, [
      el('strong', {}, String(total)),
      ` review${total === 1 ? '' : 's'} · Source arxiv math · Filed one at a time`,
    ]);
  }

  async function scheduleTypesetIn(container: HTMLElement) {
    if (!container.querySelector('[data-typeset]')) return;
    const run = async () => {
      try {
        const { typeset } = await import('../lib/latex');
        container.querySelectorAll<HTMLElement>('[data-typeset]').forEach((e) => typeset(e));
      } catch {}
    };
    const ric = (window as Window & {
      requestIdleCallback?: (cb: () => void, opts?: { timeout: number }) => number;
    }).requestIdleCallback;
    if (typeof ric === 'function') ric(() => { void run(); }, { timeout: 1500 });
    else setTimeout(() => { void run(); }, 50);
  }

  (async () => {
    const heroSlot = document.getElementById('home-hero-slot');
    const trustSlot = document.getElementById('home-trust-slot');
    const listEl = document.getElementById('home-list');
    const emptyEl = document.getElementById('home-empty');
    if (!heroSlot || !trustSlot || !listEl) return;

    let data: { generated_at: string; reviews: LatestReviewEntry[] };
    try {
      data = await dataClient.getLatest();
    } catch (err) {
      mount(heroSlot);
      mount(listEl, el('div', { class: 'state error' }, [
        el('strong', {}, 'Failed to load reviews'),
        el('span', {}, err instanceof Error ? err.message : 'Please try again.'),
      ]));
      return;
    }

    const reviews = data.reviews;
    const featured = reviews[0];

    if (featured) {
      mount(heroSlot, buildFeaturedEntry(featured, reviews.length));
    } else {
      mount(heroSlot);
    }

    trustSlot.hidden = false;
    mount(trustSlot, buildTrustStrip(reviews.length));

    const rest = reviews.slice(1);
    if (rest.length === 0) {
      mount(listEl);
      if (emptyEl && reviews.length === 0) emptyEl.hidden = false;
      // typeset hero lede if any
      if (heroSlot) await scheduleTypesetIn(heroSlot);
      return;
    }
    if (emptyEl) emptyEl.hidden = true;
    mount(listEl, ...rest.map((r) => buildFeedCard(r)));
    await scheduleTypesetIn(heroSlot);
    await scheduleTypesetIn(listEl);
  })();
</script>
