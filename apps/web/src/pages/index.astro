---
import Layout from '../components/Layout.astro';
---

<Layout
  title="OpenAgent.review"
  description="Structured AI reviews of trending arXiv papers — one reading per paper, filed as it trends."
  activeNav="home"
>
  <div class="container">
    <section class="page-intro">
      <span class="page-intro-eyebrow">The Gazette · Machine Reading Desk</span>
      <h1 class="page-intro-title">Structured AI readings of trending papers.</h1>
      <p class="page-intro-lede">
        One review per paper, filed the day it trends. Four dimension ratings,
        side-by-side — never averaged into a single score.
      </p>
    </section>

    <div id="home-hero-slot" aria-live="polite">
      <section class="hero-featured hero-featured--skel" aria-label="Loading featured filing">
        <div class="hero-featured-inner">
          <div class="hero-kicker">
            <span class="skel-block skel-line-xs" style="width:18%"></span>
            <span class="skel-block skel-line-xs" style="width:22%"></span>
            <span class="skel-block skel-line-xs" style="width:14%"></span>
          </div>
          <div>
            <div class="skel-block skel-title-big"></div>
            <div class="skel-block skel-line-md" style="margin-top:14px"></div>
            <div class="skel-block skel-line-sm" style="margin-top:6px"></div>
          </div>
          <aside class="hero-side">
            <div class="hero-side-block"><span class="skel-block skel-line-xs"></span><div class="skel-block skel-line-sm" style="margin-top:8px"></div></div>
            <div class="hero-side-block"><span class="skel-block skel-line-xs"></span><div class="skel-block skel-line-sm" style="margin-top:8px"></div></div>
            <div class="hero-side-block"><span class="skel-block skel-line-xs"></span><div class="skel-block skel-line-sm" style="margin-top:8px"></div></div>
          </aside>
        </div>
      </section>
    </div>

    <div id="home-trust-slot" class="trust-strip" aria-live="polite" hidden></div>

    <section class="stack">
      <header class="stack-header">
        <div>
          <span class="stack-eyebrow">The stack</span>
          <h2 class="stack-title">Recent filings</h2>
        </div>
        <div class="stack-aside">
          <a href="/browse/">Full browse view →</a>
        </div>
      </header>

      <div class="entry-list" id="home-list">
        {Array.from({ length: 5 }).map(() => (
          <div class="entry entry--skel" aria-hidden="true">
            <span class="entry-kicker"><span class="skel-block skel-line-xs"></span></span>
            <span class="entry-date"><span class="skel-block skel-line-xs" style="width:60%;margin-left:auto"></span></span>
            <span class="entry-title"><span class="skel-block skel-title"></span></span>
            <div class="entry-why">
              <div class="entry-why-row"><span class="entry-why-label"><span class="skel-block skel-line-xs"></span></span><span class="entry-why-text"><span class="skel-block skel-line-lg"></span></span></div>
            </div>
            <div class="entry-footer"><span class="skel-block skel-line-sm" style="width:30%"></span></div>
          </div>
        ))}
      </div>

      <div class="state empty" id="home-empty" hidden>
        <strong>No filings yet</strong>
        <span>Papers are added as the HF feed updates.</span>
      </div>
    </section>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { formatDate } from '../lib/utils';
  import { buildFeedCard, leaningLabel, confidenceBand } from '../lib/feed-card';
  import type { LatestReviewEntry } from '../lib/types';

  function recommendationWord(n: number | undefined): string {
    if (n == null) return '—';
    return ({
      1: 'Strong Reject', 2: 'Reject', 3: 'Weak Reject',
      4: 'Weak Accept',   5: 'Accept', 6: 'Strong Accept',
    } as Record<number, string>)[n] ?? '—';
  }

  function buildFeaturedEntry(entry: LatestReviewEntry, index: number, total: number): HTMLElement {
    const leaning = entry.verdict_leaning;
    const classes = ['hero-featured'];
    if (leaning) classes.push(`hero-featured--${leaning}`);

    // kicker: issue · date · arxiv category · hf rank · ethics
    const kickerBits: HTMLElement[] = [];
    kickerBits.push(el('span', { class: 'issue-no' }, `№ ${String(total).padStart(3, '0')}`));
    kickerBits.push(el('span', { class: 'kicker-sep' }, '·'));
    kickerBits.push(el('span', {}, formatDate(entry.date)));
    if (entry.hf_rank != null) {
      kickerBits.push(el('span', { class: 'kicker-sep' }, '·'));
      kickerBits.push(el('span', {}, `HF №${String(entry.hf_rank).padStart(2, '0')}`));
    }
    const cats = entry.arxiv_categories ?? [];
    if (cats.length > 0) {
      kickerBits.push(el('span', { class: 'kicker-sep' }, '·'));
      kickerBits.push(el('span', {}, cats[0]));
    }
    if (entry.ethics_flag) {
      kickerBits.push(el('span', { class: 'kicker-sep' }, '·'));
      kickerBits.push(el('span', { style: { color: 'var(--madder)' } }, '⚠ Ethics'));
    }
    const kicker = el('div', { class: 'hero-kicker' }, kickerBits);

    // title linked
    const title = el('h2', { class: 'hero-title' }, [
      el('a', { href: `/review/${encodeURIComponent(entry.id)}/` }, entry.title),
    ]);

    // lede from why_read (fallback to abstract's first sentence)
    const ledeText = entry.why_read || (entry.abstract ? entry.abstract.slice(0, 220) + '…' : '');
    const lede = el('p', { class: 'hero-lede' }, ledeText);

    // side: verdict, recommendation, confidence, why_doubt
    const side = el('aside', { class: 'hero-side', 'aria-label': 'Verdict summary' }, [
      leaning
        ? el('div', { class: 'hero-side-block' }, [
            el('span', { class: 'hero-side-label' }, 'Verdict leaning'),
            el('p', { class: 'hero-side-text' }, [
              el('em', {}, leaningLabel(leaning)),
            ]),
          ])
        : null,
      entry.overall_recommendation != null
        ? el('div', { class: 'hero-side-block' }, [
            el('span', { class: 'hero-side-label' }, `Recommendation · ${entry.overall_recommendation}/6`),
            el('p', { class: 'hero-side-text' }, recommendationWord(entry.overall_recommendation)),
          ])
        : null,
      entry.confidence != null
        ? el('div', { class: 'hero-side-block' }, [
            el('span', { class: 'hero-side-label' }, `Confidence · ${entry.confidence}/5`),
            el('p', { class: 'hero-side-text' }, [el('em', {}, confidenceBand(entry.confidence))]),
          ])
        : null,
      entry.why_doubt
        ? el('div', { class: 'hero-side-block' }, [
            el('span', { class: 'hero-side-label' }, 'Why doubt'),
            el('p', { class: 'hero-side-text' }, [el('em', {}, entry.why_doubt)]),
          ])
        : null,
    ].filter((n): n is HTMLElement => n != null));

    // foot: machine disclaimer + open link
    const foot = el('div', { class: 'hero-foot' }, [
      el('span', {}, 'Machine-generated first-pass reading · Not peer review'),
      el('a', { href: `/review/${encodeURIComponent(entry.id)}/` }, 'Open the full review →'),
    ]);

    return el('section', { class: classes.join(' '), 'aria-label': 'Featured review' }, [
      el('div', { class: 'hero-featured-inner' }, [
        kicker,
        el('div', {}, [title, lede]),
        side,
        foot,
      ]),
    ]);
  }

  function buildTrustStrip(total: number): HTMLElement {
    return el('p', { class: 'trust-strip-text' }, [
      el('strong', {}, String(total)),
      ` paper${total === 1 ? '' : 's'} · Source HF Trending · Filed on trend, never on schedule`,
    ]);
  }

  (async () => {
    const heroSlot = document.getElementById('home-hero-slot');
    const trustSlot = document.getElementById('home-trust-slot');
    const listEl = document.getElementById('home-list');
    const emptyEl = document.getElementById('home-empty');
    if (!heroSlot || !trustSlot || !listEl) return;

    let data: { generated_at: string; reviews: LatestReviewEntry[] };
    try {
      data = await dataClient.getLatest();
    } catch (err) {
      mount(heroSlot);
      mount(listEl, el('div', { class: 'state error' }, [
        el('strong', {}, 'Failed to load reviews'),
        el('span', {}, err instanceof Error ? err.message : 'Please try again.'),
      ]));
      return;
    }

    const reviews = data.reviews;
    const featured = reviews[0];

    if (featured) {
      mount(heroSlot, buildFeaturedEntry(featured, 0, reviews.length));
    } else {
      mount(heroSlot);
    }

    trustSlot.hidden = false;
    mount(trustSlot, buildTrustStrip(reviews.length));

    const rest = reviews.slice(1);
    if (rest.length === 0) {
      mount(listEl);
      if (emptyEl) emptyEl.hidden = false;
      return;
    }
    if (emptyEl) emptyEl.hidden = true;
    mount(listEl, ...rest.map((r) => buildFeedCard(r)));
  })();
</script>
