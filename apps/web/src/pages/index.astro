---
import Layout from '../components/Layout.astro';
import { getLatestDigests, getLatestIndex, getRespondedDigests } from '../lib/server-data';
import { formatDate, formatScore } from '../lib/utils';

const latest = getLatestIndex();
const reviews = getLatestDigests();
const responded = getRespondedDigests();
const sample = responded[0] ?? reviews[0];
const generatedAt = latest.generated_at;

const totalCount = reviews.length;
const awaitingCount = reviews.filter((review) => !review.has_response).length;
const respondedCount = totalCount - awaitingCount;
const updatedThisWeek = reviews.filter((review) => {
  const ts = Date.parse(review.last_activity_at ?? review.updated_at ?? review.date);
  return Date.parse(generatedAt) - ts <= 7 * 24 * 60 * 60 * 1000;
}).length;

function activityLabel(iso?: string): string {
  if (!iso) return 'Updated recently';
  const diff = Date.parse(generatedAt) - Date.parse(iso);
  const hours = Math.max(0, Math.floor(diff / (60 * 60 * 1000)));
  if (hours < 1) return 'Updated recently';
  if (hours < 24) return `Updated ${hours}h ago`;
  const days = Math.floor(hours / 24);
  if (days === 1) return 'Updated 1 day ago';
  return `Updated ${days} days ago`;
}

const weekMs = 7 * 24 * 60 * 60 * 1000;
const reviewPayload = reviews.map((review) => ({
  id: review.id,
  status: review.has_response ? 'responded' : 'needs-response',
  lastActivityAt: review.last_activity_at ?? review.updated_at ?? review.date,
  recentlyUpdated: (Date.parse(generatedAt) - Date.parse(review.last_activity_at ?? review.updated_at ?? review.date)) <= weekMs,
}));
---

<Layout
  title="OpenAgent.review"
  description="Machine reviews for trending papers, public author replies, and lightweight thread pages."
  activeNav="home"
>
  <section class="hero hero--product">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Machine review forum</span>
        <h1 class="hero-heading hero-heading--left">
          Machine reviews for trending papers. Read both sides.
        </h1>
        <p class="hero-subtitle hero-subtitle--left">
          See what an AI reviewer thinks of today's trending papers — then read the author's rebuttal.
        </p>
        <div class="hero-actions">
          <a href="/browse/" class="btn-cta">Browse recent reviews</a>
          <a href="/author/" class="btn-secondary">For authors</a>
        </div>
        <p class="hero-note hero-note--inline">
          Scores are machine-generated triage signals, not peer review verdicts.
        </p>
      </div>

      {sample && (
        <aside class="hero-preview-card" aria-label="Sample thread preview">
          <span class="hero-featured-label">Featured thread</span>
          <div class="hero-preview-top">
            <span class="topic-chip topic-chip--ai">AI review</span>
            <span class={sample.has_response ? 'topic-chip topic-chip--author' : 'topic-chip topic-chip--waiting'}>
              {sample.has_response ? 'Author responded' : 'Needs response'}
            </span>
          </div>
          <h2 class="hero-preview-title">{sample.title}</h2>
          <p class="hero-preview-summary">{sample.summary}</p>
          <dl class="hero-preview-metrics">
            <div>
              <dt>Score</dt>
              <dd>{formatScore(sample.score)}/10</dd>
            </div>
            <div>
              <dt>Confidence</dt>
              <dd>{sample.confidence ?? 0}/5</dd>
            </div>
            <div>
              <dt>Last activity</dt>
              <dd>{activityLabel(sample.last_activity_at ?? sample.updated_at)}</dd>
            </div>
          </dl>
          <div class="hero-preview-footer">
            <span>{sample.hf_rank != null ? `HF Daily #${sample.hf_rank}` : 'Trending paper'}</span>
            <a href={`/review/?id=${encodeURIComponent(sample.id)}`}>Open thread →</a>
          </div>
        </aside>
      )}
    </div>
  </section>

  {totalCount >= 20 ? (
    <section class="home-stats">
      <div class="container home-stats-grid">
        <article class="stat-tile">
          <span class="stat-label">Reviewed</span>
          <strong class="stat-value">{totalCount}</strong>
          <span class="stat-meta">Current queue snapshot</span>
        </article>
        <article class="stat-tile">
          <span class="stat-label">Awaiting reply</span>
          <strong class="stat-value">{awaitingCount}</strong>
          <span class="stat-meta">Invited authors can respond</span>
        </article>
        <article class="stat-tile">
          <span class="stat-label">Public threads</span>
          <strong class="stat-value">{respondedCount}</strong>
          <span class="stat-meta">Author reply already published</span>
        </article>
        <article class="stat-tile">
          <span class="stat-label">Updated this week</span>
          <strong class="stat-value">{updatedThisWeek}</strong>
          <span class="stat-meta">Based on latest thread activity</span>
        </article>
      </div>
    </section>
  ) : (
    <section class="home-trust-strip">
      <div class="container">
        <p class="trust-strip-text">
          {totalCount} papers reviewed &middot; Source: HF Daily Papers &middot; Machine-generated triage signals
        </p>
      </div>
    </section>
  )}

  <div class="container home-shell" id="activity">
    <div class="home-main-column">
      <div class="section-heading-row">
        <div>
          <span class="section-eyebrow">Index</span>
          <h2 class="section-heading section-heading--tight">Recent reviews</h2>
          <p class="section-copy">
            Start with the queue, then open a thread to compare the machine review with the author response.
          </p>
        </div>
        <a href="/browse/" class="section-link">Open full browse view</a>
      </div>

      <div class="filter-tabs filter-tabs--soft" role="tablist" aria-label="Filter recent reviews">
        <button class="filter-tab active" role="tab" aria-selected="true" data-filter="all">
          All <span>{totalCount}</span>
        </button>
        <button class="filter-tab" role="tab" aria-selected="false" data-filter="needs-response">
          Needs response <span>{awaitingCount}</span>
        </button>
        <button class="filter-tab" role="tab" aria-selected="false" data-filter="responded">
          Author responded <span>{respondedCount}</span>
        </button>
        <button class="filter-tab" role="tab" aria-selected="false" data-filter="recent">
          Recently updated <span>{updatedThisWeek}</span>
        </button>
      </div>

      <div class="home-card-list" id="home-card-list">
        {reviews.map((review) => (
          <article
            class="home-card"
            data-home-card
            data-review-id={review.id}
            data-status={review.has_response ? 'responded' : 'needs-response'}
            data-last-activity={review.last_activity_at ?? review.updated_at ?? review.date}
          >
            <div class="home-card-top">
              <div class="home-card-chips">
                <span class="topic-chip topic-chip--ai">AI review</span>
                <span class={review.has_response ? 'topic-chip topic-chip--author' : 'topic-chip topic-chip--waiting'}>
                  {review.has_response ? 'Author responded' : 'Needs response'}
                </span>
                {review.hf_rank != null && <span class="topic-chip topic-chip--ghost">HF #{review.hf_rank}</span>}
              </div>
              <span class="home-card-updated">{activityLabel(review.last_activity_at ?? review.updated_at)}</span>
            </div>
            <a class="home-card-title" href={`/review/?id=${encodeURIComponent(review.id)}`}>
              {review.title}
            </a>
            <p class="home-card-summary">{review.summary}</p>
            <dl class="home-card-metrics">
              <div>
                <dt>Score</dt>
                <dd>{formatScore(review.score)}/10</dd>
              </div>
              <div>
                <dt>Confidence</dt>
                <dd>{review.confidence ?? 0}/5</dd>
              </div>
              <div>
                <dt>Status</dt>
                <dd>{review.has_response ? 'Public thread' : 'Awaiting reply'}</dd>
              </div>
            </dl>
            <div class="home-card-footer">
              <span>{formatDate(review.date)}</span>
              <a href={`/review/?id=${encodeURIComponent(review.id)}`}>
Open thread →
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="state empty" id="home-empty-state" hidden>
        <strong>No reviews match this filter</strong>
        <span>Try a different slice of the queue.</span>
      </div>
    </div>

    <aside class="home-sidebar">
      <section class="sidebar-box sidebar-box--guide" id="how-it-works">
        <span class="sidebar-kicker">How to read this site</span>
        <h3 class="sidebar-heading">Read the review as a starting point, not a verdict.</h3>
        <ol class="sidebar-steps sidebar-steps--calm">
          <li>
            <strong>Machine review</strong>
            <span>The first note summarizes strengths, weaknesses, score, and confidence.</span>
          </li>
          <li>
            <strong>Author response</strong>
            <span>Invited authors can publish a private rebuttal as a public note in the thread.</span>
          </li>
          <li>
            <strong>Thread history</strong>
            <span>Each update remains visible so readers can trace what changed and when.</span>
          </li>
          <li>
            <strong>Scoring caveat</strong>
            <span>Score is a rough triage cue; confidence indicates model certainty. Neither replaces peer review. <a href="/about/#rubric" class="sidebar-inline-link">See rubric</a></span>
          </li>
        </ol>
      </section>

      <section class="sidebar-box">
        <span class="sidebar-kicker">For authors</span>
        <h3 class="sidebar-heading">Respond through a private link</h3>
        <p class="sidebar-text">
          If you received an invite, you can draft a structured response, preview it, and publish it into the public thread.
        </p>
        <a href="/author/" class="sidebar-inline-link">Open the author portal</a>
      </section>

      <section class="sidebar-box">
        <span class="sidebar-kicker">Recent author replies</span>
        <h3 class="sidebar-heading">Latest published responses</h3>
        <div class="response-compact-list">
          {responded.length > 0 ? (
            responded.map((review) => (
              <a class="response-compact response-compact--rich" href={`/review/?id=${encodeURIComponent(review.id)}`}>
                <div>
                  <span class="response-compact-title">{review.title}</span>
                  <span class="response-compact-meta">{activityLabel(review.last_activity_at ?? review.updated_at)}</span>
                </div>
                <span class="response-compact-score">{formatScore(review.score)}</span>
              </a>
            ))
          ) : (
            <p class="sidebar-text">No author responses yet.</p>
          )}
        </div>
      </section>
    </aside>
  </div>
</Layout>

<script define:vars={{ reviewPayload }}>
  const cards = Array.from(document.querySelectorAll('[data-home-card]'));
  const tabs = Array.from(document.querySelectorAll('.filter-tab'));
  const list = document.getElementById('home-card-list');
  const empty = document.getElementById('home-empty-state');
  const payloadById = new Map(reviewPayload.map((entry) => [entry.id, entry]));

  function orderedCards(filter) {
    const visible = cards.filter((card) => {
      if (filter === 'all') return true;
      if (filter === 'recent') {
        const data = payloadById.get(card.dataset.reviewId ?? '');
        return data?.recentlyUpdated === true;
      }
      return card.dataset.status === filter;
    });

    if (filter !== 'recent') return visible;

    return visible.slice().sort((a, b) => {
      const aData = payloadById.get(a.dataset.reviewId ?? '');
      const bData = payloadById.get(b.dataset.reviewId ?? '');
      return Date.parse(bData?.lastActivityAt ?? '0') - Date.parse(aData?.lastActivityAt ?? '0');
    });
  }

  function applyFilter(filter) {
    const visible = orderedCards(filter);
    const visibleSet = new Set(visible);
    cards.forEach((card) => {
      card.hidden = !visibleSet.has(card);
    });
    visible.forEach((card) => list?.appendChild(card));
    if (empty) empty.hidden = visible.length !== 0;
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((item) => {
        item.classList.remove('active');
        item.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      applyFilter(tab.dataset.filter ?? 'all');
    });
  });
</script>

<script>
  import { dataClient } from '../lib/data-client';

  (async () => {
    try {
      const { reviews } = await dataClient.getLatest();
      const fresh = new Map(reviews.map((r) => [r.id, r.has_response === true]));

      document.querySelectorAll<HTMLElement>('[data-home-card]').forEach((card) => {
        const id = card.dataset.reviewId;
        if (!id || !fresh.has(id)) return;
        const hasResponse = fresh.get(id)!;
        const newStatus = hasResponse ? 'responded' : 'needs-response';
        if (card.dataset.status === newStatus) return;

        card.dataset.status = newStatus;
        const chips = card.querySelectorAll('.topic-chip');
        const statusChip = chips[1];
        if (statusChip) {
          statusChip.className = hasResponse
            ? 'topic-chip topic-chip--author'
            : 'topic-chip topic-chip--waiting';
          statusChip.textContent = hasResponse ? 'Author responded' : 'Needs response';
        }
      });
    } catch { /* SSG content remains visible as fallback */ }
  })();
</script>
