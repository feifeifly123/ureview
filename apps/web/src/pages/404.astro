---
import Layout from '../components/Layout.astro';
---

<Layout title="Not found" description="The page you requested could not be found.">
  <div class="not-found-shell">
    <div class="not-found-code">404</div>
    <h1 class="not-found-title">Page not found.</h1>
    <p class="not-found-body">
      The link may be out of date, the paper may have moved, or the route
      may never have existed.
    </p>
    <div class="not-found-links">
      <a href="/browse/">Browse recent reviews</a>
      <a href="/about/">About the gazette</a>
      <a href="/">Back to the masthead</a>
    </div>
  </div>
</Layout>
