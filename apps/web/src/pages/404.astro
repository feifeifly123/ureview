---
import Layout from '../components/Layout.astro';
---

<Layout title="Not found" description="The page you requested could not be found.">
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span>404</span>
      </nav>
      <h1>Page not found</h1>
      <p class="subtitle">
        The link may be out of date, the paper may have moved, or the route may not exist yet.
      </p>
    </div>
  </div>

  <div class="container not-found-shell">
    <a class="not-found-card" href="/browse/">
      <strong>Browse recent reviews</strong>
      <span>Return to the main queue and open a thread from there.</span>
    </a>
    <a class="not-found-card" href="/about/">
      <strong>Read how the site works</strong>
      <span>See the rubric, caveats, and author response policy.</span>
    </a>
    <a class="not-found-card" href="/author/">
      <strong>Open the author portal</strong>
      <span>Paste a private invite token or review the author flow.</span>
    </a>
  </div>
</Layout>
