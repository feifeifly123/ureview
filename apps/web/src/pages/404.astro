---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Not found"
  description="The page you requested could not be found."
>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span>404</span>
      </nav>
      <h1>Page not found</h1>
      <p class="subtitle">
        The page you requested doesn't exist — it may have moved, or the link
        may be out of date.
      </p>
    </div>
  </div>

  <div class="container">
    <section class="content">
      <div class="prose">
        <h2>Where to next?</h2>
        <ul>
          <li><a href="/">Recent reviews</a> — latest paper reviews</li>
          <li><a href="/about/">About</a> — what this site is</li>
        </ul>
      </div>
    </section>
  </div>
</Layout>
