---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Review"
  description="AI review note for a research paper."
  chrome="forum"
  hideFooter={true}
>
  <div class="thread-page-shell">
    <article class="thread-page-root" id="review-detail">
      <div class="state loading">
        <strong>Loading review…</strong>
      </div>
    </article>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { formatDate, safeHref } from '../lib/utils';
  import type { Review } from '../lib/types';

  function paragraphs(text: string): HTMLElement[] {
    return text
      .split(/\n\s*\n/)
      .map((block) => block.trim())
      .filter((block) => block.length > 0)
      .map((block) => el('p', {}, block));
  }

  function buildHeader(review: Review): HTMLElement {
    const chips: HTMLElement[] = [el('span', { class: 'topic-chip topic-chip--ai' }, 'AI review')];
    if (review.hf_rank != null) {
      chips.push(el('span', { class: 'topic-chip topic-chip--ghost' }, `HF #${review.hf_rank}`));
    }

    return el('section', { class: 'thread-header fade-in' }, [
      el('div', { class: 'thread-header-top' }, [
        el('div', { class: 'thread-header-copy' }, [
          el('h1', { class: 'thread-header-title' }, review.title),
          el('div', { class: 'thread-header-meta' }, [
            el('span', {}, `Reviewed ${formatDate(review.date)}`),
          ]),
          el('div', { class: 'thread-header-filters' }, [
            el('div', { class: 'thread-header-chips' }, chips),
          ]),
        ]),
        el('div', { class: 'thread-header-actions' }, [
          el(
            'a',
            {
              class: 'btn-secondary btn-secondary--compact',
              href: safeHref(review.paper_url),
              target: '_blank',
              rel: 'noopener',
            },
            'Open paper'
          ),
          el(
            'button',
            {
              class: 'btn-secondary btn-secondary--compact',
              type: 'button',
              'data-copy-link': 'true',
            },
            'Copy link'
          ),
        ]),
      ]),
    ]);
  }

  function buildContent(review: Review): HTMLElement {
    return el('div', { class: 'thread-content-stack' }, [
      el('section', { class: 'thread-content-card' }, [
        el('span', { class: 'thread-highlight-label' }, 'Abstract \u2014 from arXiv'),
        ...paragraphs(review.abstract),
      ]),
      el('section', { class: 'thread-content-card thread-content-card--review' }, [
        el('span', { class: 'thread-highlight-label' }, 'AI review'),
        ...paragraphs(review.ai_review),
      ]),
    ]);
  }

  function attachCopyLink(container: HTMLElement) {
    const copyButton = container.querySelector<HTMLButtonElement>('[data-copy-link]');
    copyButton?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyButton.textContent = 'Copied';
        setTimeout(() => { copyButton.textContent = 'Copy link'; }, 1200);
      } catch {
        copyButton.textContent = 'Copy failed';
        setTimeout(() => { copyButton.textContent = 'Copy link'; }, 1200);
      }
    });
  }

  function renderPage(container: HTMLElement, review: Review) {
    const page = el('div', { class: 'thread-main-column' }, [
      buildHeader(review),
      buildContent(review),
    ]);
    mount(container, page);
    attachCopyLink(container);
  }

  function errorState(title: string, detail: string): HTMLElement {
    return el('div', { class: 'state error' }, [
      el('strong', {}, title),
      el('span', {}, detail),
    ]);
  }

  async function main() {
    const container = document.getElementById('review-detail');
    const id = new URLSearchParams(window.location.search).get('id');
    if (!container) return;

    if (!id) {
      mount(container, errorState('Missing review ID', 'No ?id= parameter supplied.'));
      return;
    }

    let review: Review;
    try {
      review = await dataClient.getReview(id);
    } catch (e) {
      mount(container, errorState('Failed to load review', e instanceof Error ? e.message : String(e)));
      return;
    }

    document.title = `${review.title} \u2014 OpenAgent.review`;
    renderPage(container, review);
  }

  main();
</script>
