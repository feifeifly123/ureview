---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Review"
  description="AI-generated review of a research paper."
>
  <div class="container">
    <article class="content" id="review-detail">
      <div class="state loading">
        <strong>Loading review</strong>
      </div>
    </article>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { threadBlock, buildReviewBody, buildParagraphs, stateView } from '../lib/render';
  import { formatDate } from '../lib/utils';
  import type { Review, ThreadData } from '../lib/types';

  const BADGE_LABELS: Record<string, string> = {
    review: 'Official Review',
    rebuttal: 'Rebuttal',
    acknowledgement: 'Rebuttal Acknowledgement',
    reply_comment: 'Reply Rebuttal Comment',
  };

  /** OpenReview-style paper header. */
  function buildHeader(r: Review): HTMLElement {
    const dateStr = formatDate(r.date);

    const metaItems: (Node | string)[] = [
      el('span', {}, `${dateStr}`),
    ];
    if (r.hf_rank != null) {
      metaItems.push(
        el('span', { class: 'or-meta-sep' }, '\u00B7'),
        el('span', {}, `HF Daily #${r.hf_rank}`)
      );
    }

    const actions = el('div', { class: 'or-paper-actions' }, [
      el(
        'a',
        {
          class: 'btn btn-primary',
          href: r.paper_url,
          target: '_blank',
          rel: 'noopener',
        },
        'Read PDF \u2192'
      ),
      el('a', { class: 'btn', href: `/day/?date=${encodeURIComponent(r.date)}` }, `Browse ${dateStr}`),
    ]);

    return el('header', { class: 'or-paper-header fade-in' }, [
      el('h1', { class: 'or-paper-title' }, r.title),
      el('div', { class: 'or-paper-meta' }, metaItems),
      el('div', { class: 'or-paper-section' }, [
        el('span', { class: 'or-paper-label' }, 'Abstract: '),
        el('span', { class: 'or-paper-text' }, r.summary),
      ]),
      actions,
    ]);
  }

  async function main() {
    const container = document.getElementById('review-detail')!;
    const id = new URLSearchParams(window.location.search).get('id');

    if (!id) {
      mount(container, stateView('error', 'Missing review ID', 'No ?id= parameter supplied.'));
      return;
    }

    let review: Review;
    let threadData: ThreadData | null;
    try {
      [review, threadData] = await Promise.all([
        dataClient.getReview(id),
        dataClient.getThread(id),
      ]);
    } catch (e) {
      mount(
        container,
        stateView('error', 'Failed to load review', e instanceof Error ? e.message : String(e))
      );
      return;
    }

    document.title = `${review.title} — Ureview.ai`;

    // First thread entry: Official Review
    const reviewEntry = threadBlock({
      type: 'review',
      title: `Official Review by Ureview.ai Agent`,
      byLine: 'by Ureview.ai Agent',
      date: review.updated_at,
      body: buildReviewBody(review.review),
    });

    // Subsequent thread entries
    const threadNodes: HTMLElement[] = [];
    const parentLabels = ['Official Review by Ureview.ai Agent'];

    if (threadData && threadData.thread.length > 0) {
      for (const entry of threadData.thread) {
        const parentLabel = parentLabels[parentLabels.length - 1];
        const isAgent = entry.type === 'acknowledgement';
        const byName = isAgent ? 'Ureview.ai Agent' : (entry.author_name ?? 'Authors');
        const badgeLabel = BADGE_LABELS[entry.type] ?? entry.type;
        const title = `${badgeLabel} by ${byName}`;

        threadNodes.push(
          threadBlock({
            type: entry.type,
            title,
            byLine: `by ${byName}`,
            date: entry.submitted_at,
            replyTo: parentLabel,
            body: buildParagraphs(entry.content, entry.type),
          })
        );

        parentLabels.push(title);
      }
    }

    const thread = el('div', { class: 'or-thread' }, [reviewEntry, ...threadNodes]);

    mount(container, buildHeader(review), thread);
  }

  main();
</script>
