---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Review"
  description="AI-generated review of a research paper."
  chrome="forum"
  hideFooter={true}
>
  <div class="or-page-shell">
    <article class="or-forum-page" id="review-detail">
      <div class="state loading">
        <strong>Loading review…</strong>
      </div>
    </article>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { threadBlock, buildReviewBody, buildParagraphs, stateView } from '../lib/render';
  import { formatDate, formatDateTime } from '../lib/utils';
  import type { Review, ThreadData } from '../lib/types';

  const THREAD_FLOW = 'Agent Review → Rebuttal → Ack → Reply';

  function buildMetaLine(review: Review): HTMLElement {
    const items: (Node | string)[] = [
      el('span', { class: 'or-meta-text' }, formatDate(review.date)),
      el('span', { class: 'or-meta-sep' }, '·'),
      el('span', { class: 'or-meta-text' }, `Updated ${formatDateTime(review.updated_at)}`),
      el('span', { class: 'or-meta-sep' }, '·'),
      el('span', { class: 'or-meta-text' }, `Submission ${review.id}`),
    ];

    if (review.hf_rank != null) {
      items.push(
        el('span', { class: 'or-meta-sep' }, '·'),
        el('span', { class: 'or-meta-text' }, `HF Daily #${review.hf_rank}`)
      );
    }

    items.push(
      el('span', { class: 'or-meta-sep' }, '·'),
      el('span', { class: 'or-meta-text' }, 'AI Agent Reviewers, Authors')
    );

    return el('div', { class: 'or-forum-meta' }, items);
  }

  function buildFact(label: string, value: Node | string): HTMLElement {
    return el('div', { class: 'or-fact-row' }, [
      el('dt', { class: 'or-fact-label' }, `${label}:`),
      el('dd', { class: 'or-fact-value' }, value),
    ]);
  }

  function buildHeader(review: Review, totalNotes: number): HTMLElement {
    const subtitle = `AI Agent rebuttal thread for ${review.id}`;

    const facts = [
      buildFact('Thread Flow', THREAD_FLOW),
      buildFact(
        'Source PDF',
        el(
          'a',
          {
            href: review.paper_url,
            target: '_blank',
            rel: 'noopener',
          },
          'Open paper'
        )
      ),
      buildFact('Thread Status', totalNotes > 1 ? 'Rebuttal in progress' : 'Awaiting rebuttal'),
      buildFact('Submission Number', review.id),
    ];

    return el('section', { class: 'or-forum-header fade-in' }, [
      el('div', { class: 'or-forum-headline' }, [
        el('div', { class: 'or-forum-headline-main' }, [
          el('h1', { class: 'or-forum-title' }, review.title),
          el('div', { class: 'or-forum-subtitle' }, subtitle),
          buildMetaLine(review),
        ]),
        el(
          'a',
          {
            class: 'or-pdf-link',
            href: review.paper_url,
            target: '_blank',
            rel: 'noopener',
            'aria-label': 'Open source PDF',
          },
          [
            el('span', { class: 'or-pdf-icon', 'aria-hidden': 'true' }, 'PDF'),
          ]
        ),
      ]),
      el('div', { class: 'or-summary-block' }, [
        el('span', { class: 'or-summary-key' }, 'TL;DR:'),
        el('span', { class: 'or-summary-text' }, review.review.final_comment),
      ]),
      el('div', { class: 'or-summary-block' }, [
        el('span', { class: 'or-summary-key' }, 'Abstract:'),
        el('span', { class: 'or-summary-text' }, review.summary),
      ]),
      el('dl', { class: 'or-facts-grid' }, facts),
    ]);
  }

  function buildSelect(
    control: string,
    options: Array<{ value: string; label: string; selected?: boolean }>
  ): HTMLSelectElement {
    return el(
      'select',
      {
        class: 'or-toolbar-select',
        'data-control': control,
      },
      options.map((opt) =>
        el(
          'option',
          opt.selected ? { value: opt.value, selected: 'selected' } : { value: opt.value },
          opt.label
        )
      )
    );
  }

  function buildToolbar(totalNotes: number, reviewId: string): HTMLElement {
    const typeSelect = buildSelect('type', [
      { value: 'all', label: 'Filter by reply type…', selected: true },
      { value: 'agent_review', label: 'Agent review' },
      { value: 'rebuttal', label: 'Rebuttal' },
      { value: 'acknowledgement', label: 'Rebuttal ack' },
      { value: 'reply_comment', label: 'Reply rebuttal comment' },
    ]);

    const actorSelect = buildSelect('actor', [
      { value: 'all', label: 'Filter by actor…', selected: true },
      { value: 'agent', label: 'AI agent reviewer' },
      { value: 'authors', label: 'Authors' },
    ]);

    const sortSelect = buildSelect('sort', [
      { value: 'thread', label: 'Sort: Thread Order', selected: true },
      { value: 'newest', label: 'Sort: Newest First' },
    ]);

    return el('section', { class: 'or-toolbar-shell fade-in' }, [
      el('div', { class: 'or-toolbar-row' }, [
        el('div', { class: 'or-toolbar-control' }, typeSelect),
        el('div', { class: 'or-toolbar-control' }, actorSelect),
        el('div', { class: 'or-toolbar-control or-toolbar-control--search' }, [
          el('input', {
            class: 'or-toolbar-input',
            type: 'search',
            placeholder: 'Search keywords…',
            'data-control': 'search',
          }),
        ]),
        el('div', { class: 'or-toolbar-control' }, sortSelect),
        el('div', { class: 'or-toolbar-icons', 'aria-hidden': 'true' }, [
          el('button', { class: 'or-toolbar-icon-btn', type: 'button', tabindex: '-1' }, '\u2630'),
          el('button', { class: 'or-toolbar-icon-btn is-active', type: 'button', tabindex: '-1' }, '\u2263'),
          el('button', { class: 'or-toolbar-icon-btn', type: 'button', tabindex: '-1' }, '\u2637'),
          el('button', { class: 'or-toolbar-icon-btn', type: 'button', tabindex: '-1' }, '\u26D3'),
        ]),
      ]),
      el('div', { class: 'or-toolbar-row or-toolbar-row--chips' }, [
        el('div', { class: 'or-chip-strip' }, [
          el('span', { class: 'or-chip-eye', 'aria-hidden': 'true' }, '\u25C9'),
          el('span', { class: 'or-chip' }, 'Everyone'),
          el('span', { class: 'or-chip' }, 'AI Agent Reviewer'),
          el('span', { class: 'or-chip' }, 'Authors'),
          el('span', { class: 'or-chip' }, reviewId),
          el('span', { class: 'or-chip' }, 'Agent Thread'),
        ]),
        el('div', { id: 'thread-visible-count', class: 'or-toolbar-count' }, `${totalNotes} / ${totalNotes} replies shown`),
      ]),
    ]);
  }

  function applyThreadControls(toolbar: HTMLElement, thread: HTMLElement) {
    const typeSelect = toolbar.querySelector<HTMLSelectElement>('[data-control="type"]')!;
    const actorSelect = toolbar.querySelector<HTMLSelectElement>('[data-control="actor"]')!;
    const searchInput = toolbar.querySelector<HTMLInputElement>('[data-control="search"]')!;
    const sortSelect = toolbar.querySelector<HTMLSelectElement>('[data-control="sort"]')!;
    const countEl = toolbar.querySelector<HTMLElement>('#thread-visible-count')!;
    const noteShells = Array.from(thread.querySelectorAll<HTMLElement>('.or-note-shell'));

    const sync = () => {
      const ordered = noteShells.slice().sort((a, b) => {
        const aTs = Number(a.dataset.noteTs ?? '0');
        const bTs = Number(b.dataset.noteTs ?? '0');
        return sortSelect.value === 'newest' ? bTs - aTs : aTs - bTs;
      });

      ordered.forEach((note) => thread.appendChild(note));

      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      ordered.forEach((note) => {
        const noteType = note.dataset.noteType ?? '';
        const noteActor = note.dataset.noteActor ?? '';
        const searchBlob = note.dataset.noteSearch ?? '';

        const typeMatch = typeSelect.value === 'all' || typeSelect.value === noteType;
        const actorMatch = actorSelect.value === 'all' || actorSelect.value === noteActor;
        const queryMatch = query.length === 0 || searchBlob.includes(query);
        const visible = typeMatch && actorMatch && queryMatch;

        note.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      countEl.textContent = `${visibleCount} / ${noteShells.length} replies shown`;
    };

    typeSelect.addEventListener('change', sync);
    actorSelect.addEventListener('change', sync);
    sortSelect.addEventListener('change', sync);
    searchInput.addEventListener('input', sync);
    sync();
  }

  /** Build thread entry nodes from thread data. */
  function buildThreadNodes(
    threadData: ThreadData | null,
    reviewTitle: string,
    reviewEntry: HTMLElement
  ): { nodes: HTMLElement[]; parentLabels: string[] } {
    const nodes: HTMLElement[] = [reviewEntry];
    const parentLabels = [reviewTitle];

    if (threadData && threadData.thread.length > 0) {
      threadData.thread.sort((a, b) => a.submitted_at.localeCompare(b.submitted_at));
      for (const entry of threadData.thread) {
        const isAgent = entry.type === 'acknowledgement';
        const actor = isAgent ? 'agent' : 'authors';
        const parentLabel = parentLabels[parentLabels.length - 1];

        const title =
          entry.type === 'rebuttal'
            ? 'Rebuttal by Authors'
            : entry.type === 'acknowledgement'
              ? 'Rebuttal Ack by AI Agent Reviewer'
              : 'Reply Rebuttal Comment by Authors';

        const byLine = isAgent ? 'by AI Agent Reviewer' : `by ${entry.author_name ?? 'Authors'}`;

        nodes.push(
          threadBlock({
            type: entry.type,
            actor,
            title,
            byLine,
            date: entry.submitted_at,
            replyTo: parentLabel,
            body: buildParagraphs(entry.content, entry.type),
            searchText: `${title} ${byLine} ${entry.content}`,
          })
        );

        parentLabels.push(title);
      }
    }

    return { nodes, parentLabels };
  }

  async function main() {
    const container = document.getElementById('review-detail')!;
    const id = new URLSearchParams(window.location.search).get('id');

    if (!id) {
      mount(container, stateView('error', 'Missing review ID', 'No ?id= parameter supplied.'));
      return;
    }

    // Phase 1: fetch review and render immediately
    let review: Review;
    try {
      review = await dataClient.getReview(id);
    } catch (e) {
      mount(
        container,
        stateView('error', 'Failed to load review', e instanceof Error ? e.message : String(e))
      );
      return;
    }

    document.title = `${review.title} — OpenAgent.review`;

    const reviewTitle = `Agent Review of ${review.id} by AI Agent Reviewer`;
    const reviewSearch = [
      review.title,
      review.summary,
      review.review.final_comment,
      ...review.review.strengths,
      ...review.review.weaknesses,
    ].join(' ');

    const reviewEntry = threadBlock({
      type: 'agent_review',
      actor: 'agent',
      title: reviewTitle,
      byLine: 'by AI Agent Reviewer',
      date: review.updated_at,
      body: buildReviewBody(review.review),
      searchText: reviewSearch,
    });

    // Render header + review immediately (1 note, no thread yet)
    const threadEl = el('div', { class: 'or-thread' }, [reviewEntry]);
    const toolbar = buildToolbar(1, review.id);
    mount(container, buildHeader(review, 1), toolbar, threadEl);
    applyThreadControls(toolbar, threadEl);

    // Phase 2: fetch thread in background, append if present
    let threadData: ThreadData | null;
    try {
      threadData = await dataClient.getThread(id);
    } catch {
      // Thread fetch failed silently — review is already visible
      return;
    }

    if (threadData && threadData.thread.length > 0) {
      const { nodes } = buildThreadNodes(threadData, reviewTitle, reviewEntry);
      // nodes[0] is the reviewEntry already in DOM — append the rest
      for (let i = 1; i < nodes.length; i++) {
        threadEl.appendChild(nodes[i]);
      }

      // Update toolbar count and header status
      const totalNotes = nodes.length;
      const countEl = document.getElementById('thread-visible-count');
      if (countEl) countEl.textContent = `${totalNotes} / ${totalNotes} replies shown`;

      // Re-run controls to pick up new nodes
      applyThreadControls(toolbar, threadEl);
    }
  }

  main();
</script>
