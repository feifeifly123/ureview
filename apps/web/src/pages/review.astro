---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Review"
  description="Structured AI review note for a research paper."
  chrome="forum"
  hideFooter={true}
>
  <div class="thread-page-shell">
    <article class="review-page-root" id="review-detail">
      <div class="state loading">
        <strong>Loading review…</strong>
      </div>
    </article>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { formatDate, safeHref } from '../lib/utils';
  import { typeset } from '../lib/latex';
  import { leaningLabel, confidenceBand } from '../lib/feed-card';
  import type { Review, KeyQuestion, AIReviewRatings, VerdictLeaning } from '../lib/types';

  const RECOMMENDATION_LABELS: Record<number, string> = {
    1: 'Strong Reject',
    2: 'Reject',
    3: 'Weak Reject',
    4: 'Weak Accept',
    5: 'Accept',
    6: 'Strong Accept',
  };

  function recommendationLabel(n: number | undefined): string {
    if (n == null) return '—';
    return RECOMMENDATION_LABELS[n] ?? '—';
  }

  function paragraphs(text: string, markClass: string | null = null): HTMLElement[] {
    return text
      .split(/\n\s*\n/)
      .map((block) => block.trim())
      .filter((block) => block.length > 0)
      .map((block) => {
        const p = el('p', markClass ? { class: markClass } : {}, block);
        return p;
      });
  }

  function firstSentence(text: string): string {
    const trimmed = text.trim();
    const match = trimmed.match(/^(.+?[.!?])(\s|$)/);
    return match ? match[1] : trimmed;
  }

  // ---------- banner + layer 1 ----------

  function buildEthicsBanner(review: Review): HTMLElement | null {
    const ai = review.ai_review;
    if (!ai.ethics_flag) return null;
    const kids: HTMLElement[] = [
      el('strong', {}, '\u26A0  Flagged for ethics review'),
    ];
    if (ai.ethics_concerns) {
      kids.push(el('p', {}, ai.ethics_concerns));
    }
    return el('div', { class: 'ethics-banner', role: 'alert' }, kids);
  }

  function buildSpeedread(review: Review): HTMLElement {
    const ai = review.ai_review;
    const highlights = review.review_highlights;

    const chips: HTMLElement[] = [el('span', { class: 'topic-chip topic-chip--ai' }, 'AI review')];
    if (review.hf_rank != null) {
      chips.push(el('span', { class: 'topic-chip topic-chip--ghost' }, `HF #${review.hf_rank}`));
    }
    (review.arxiv_categories ?? []).forEach((cat) => {
      chips.push(el('span', { class: 'topic-chip topic-chip--ghost' }, cat));
    });

    const verdictRow = el('div', { class: 'verdict-row' }, [
      el(
        'span',
        { class: `leaning-pill leaning-pill--${highlights.verdict_leaning} leaning-pill--lg` },
        leaningLabel(highlights.verdict_leaning)
      ),
      el('span', { class: 'verdict-sep' }, '\u00b7'),
      el('span', { class: 'verdict-metric' }, [
        el('span', { class: 'verdict-metric-label' }, 'Recommendation'),
        el('span', { class: 'verdict-metric-value' }, [
          el('strong', {}, String(ai.overall_recommendation)),
          el('span', { class: 'verdict-metric-scale' }, '/ 6'),
          el('span', { class: 'verdict-metric-band' }, recommendationLabel(ai.overall_recommendation)),
        ]),
      ]),
      el('span', { class: 'verdict-sep' }, '\u00b7'),
      el('span', { class: 'verdict-metric' }, [
        el('span', { class: 'verdict-metric-label' }, 'Confidence'),
        el('span', { class: 'verdict-metric-value' }, [
          el('strong', {}, String(ai.confidence)),
          el('span', { class: 'verdict-metric-scale' }, '/ 5'),
          el('span', { class: 'verdict-metric-band' }, confidenceBand(ai.confidence)),
        ]),
      ]),
    ]);

    return el('section', { class: 'review-header fade-in' }, [
      el('div', { class: 'review-header-top' }, [
        el('div', { class: 'review-header-copy' }, [
          el('h1', { class: 'review-header-title' }, review.title),
          el('div', { class: 'review-header-meta' }, [
            el('span', {}, `Reviewed ${formatDate(review.date)}`),
          ]),
          el('div', { class: 'review-header-chips' }, chips),
        ]),
        el('div', { class: 'review-header-actions' }, [
          el(
            'a',
            {
              class: 'btn-secondary btn-secondary--compact',
              href: safeHref(review.paper_url),
              target: '_blank',
              rel: 'noopener',
            },
            'Open paper'
          ),
          el(
            'button',
            { class: 'btn-secondary btn-secondary--compact', type: 'button', 'data-copy-link': 'true' },
            'Copy link'
          ),
        ]),
      ]),
      el('div', { class: 'review-verdict-card' }, [
        verdictRow,
        el('p', { class: 'review-verdict-lead', 'data-typeset': 'true' }, firstSentence(ai.summary)),
        el(
          'p',
          { class: 'review-verdict-disclaimer' },
          'Machine-generated first-pass review, not peer review.'
        ),
      ]),
    ]);
  }

  // ---------- layer 2: judgment ----------

  const DIMENSIONS: { key: keyof AIReviewRatings; label: string }[] = [
    { key: 'soundness', label: 'Soundness' },
    { key: 'presentation', label: 'Presentation' },
    { key: 'significance', label: 'Significance' },
    { key: 'originality', label: 'Originality' },
  ];

  function buildJudgment(review: Review): HTMLElement {
    const ai = review.ai_review;
    const dims = DIMENSIONS.map(({ key, label }) => {
      const r = ai.ratings[key];
      return el('article', { class: 'dimension-card' }, [
        el('div', { class: 'dimension-head' }, [
          el('span', { class: 'dimension-label' }, label),
          el('span', { class: 'dimension-score' }, [
            el('strong', {}, String(r.score)),
            el('span', {}, ' / 4'),
          ]),
        ]),
        el('p', { class: 'dimension-note', 'data-typeset': 'true' }, r.note),
      ]);
    });

    return el('section', { class: 'review-section', id: 'judgment' }, [
      el('span', { class: 'sidebar-kicker' }, 'Judgment'),
      el('h2', { class: 'review-section-title' }, 'Four dimensions'),
      el('div', { class: 'review-prose', 'data-typeset': 'true' }, paragraphs(ai.summary)),
      el('div', { class: 'dimension-grid' }, dims),
      el(
        'details',
        { class: 'review-details' },
        [
          el('summary', {}, 'Read the full strengths & weaknesses'),
          el(
            'div',
            { class: 'review-prose', 'data-typeset': 'true' },
            paragraphs(ai.strengths_weaknesses)
          ),
        ]
      ),
    ]);
  }

  // ---------- layer 3: what would change the verdict ----------

  function buildKeyQuestions(review: Review): HTMLElement | null {
    const qs = review.ai_review.key_questions ?? [];
    if (qs.length === 0) return null;

    const items = qs.map((q: KeyQuestion, i: number) =>
      el('article', { class: 'kq-card' }, [
        el('div', { class: 'kq-num' }, String(i + 1)),
        el('div', { class: 'kq-body' }, [
          el('p', { class: 'kq-question', 'data-typeset': 'true' }, q.question),
          q.tag ? el('span', { class: 'kq-tag' }, q.tag) : null,
        ].filter((n): n is HTMLElement => n != null)),
      ])
    );

    return el('section', { class: 'review-section', id: 'questions' }, [
      el('span', { class: 'sidebar-kicker' }, 'Follow-up'),
      el('h2', { class: 'review-section-title' }, 'What would change this verdict'),
      el('div', { class: 'kq-list' }, items),
    ]);
  }

  // ---------- layer 4: abstract, limits, raw ----------

  function buildAbstract(review: Review): HTMLElement {
    return el('section', { class: 'review-section', id: 'abstract' }, [
      el('span', { class: 'sidebar-kicker' }, 'From arXiv'),
      el('h2', { class: 'review-section-title' }, 'Abstract'),
      el(
        'div',
        { class: 'review-prose review-prose--abstract', 'data-typeset': 'true' },
        paragraphs(review.abstract)
      ),
    ]);
  }

  function buildLimits(review: Review): HTMLElement | null {
    const text = review.ai_review.limitations?.trim();
    if (!text) return null;
    return el('section', { class: 'review-section', id: 'limits' }, [
      el('span', { class: 'sidebar-kicker' }, 'Caveats'),
      el('h2', { class: 'review-section-title' }, 'Limits & caveats'),
      el('div', { class: 'review-prose', 'data-typeset': 'true' }, paragraphs(text)),
    ]);
  }

  function buildRaw(review: Review): HTMLElement {
    const ai = review.ai_review;
    const composite = [ai.summary, ai.strengths_weaknesses, ai.limitations]
      .filter((x) => !!x && x.trim().length > 0)
      .join('\n\n');

    return el('section', { class: 'review-section review-section--raw', id: 'raw' }, [
      el('span', { class: 'sidebar-kicker' }, 'Audit'),
      el('h2', { class: 'review-section-title' }, 'Raw agent review'),
      el(
        'p',
        { class: 'review-section-intro' },
        'The agent\u2019s original prose, joined end-to-end without our structuring.'
      ),
      el('div', { class: 'review-prose review-prose--raw', 'data-typeset': 'true' }, paragraphs(composite)),
    ]);
  }

  // ---------- structured/raw toggle ----------

  function buildModeToggle(): HTMLElement {
    return el('div', { class: 'view-toggle', role: 'tablist', 'aria-label': 'Review view mode' }, [
      el(
        'button',
        {
          class: 'view-toggle-btn active',
          type: 'button',
          role: 'tab',
          'aria-selected': 'true',
          'data-view-mode': 'structured',
        },
        'Structured'
      ),
      el(
        'button',
        {
          class: 'view-toggle-btn',
          type: 'button',
          role: 'tab',
          'aria-selected': 'false',
          'data-view-mode': 'raw',
        },
        'Raw'
      ),
    ]);
  }

  function applyViewMode(container: HTMLElement, mode: 'structured' | 'raw') {
    container.setAttribute('data-view', mode);
    container.querySelectorAll<HTMLButtonElement>('.view-toggle-btn').forEach((btn) => {
      const isActive = btn.dataset.viewMode === mode;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
  }

  function attachModeToggle(container: HTMLElement) {
    applyViewMode(container, 'structured');
    container.querySelectorAll<HTMLButtonElement>('.view-toggle-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = (btn.dataset.viewMode as 'structured' | 'raw') ?? 'structured';
        applyViewMode(container, next);
      });
    });
  }

  function attachCopyLink(container: HTMLElement) {
    const copyButton = container.querySelector<HTMLButtonElement>('[data-copy-link]');
    copyButton?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyButton.textContent = 'Copied';
        setTimeout(() => { copyButton.textContent = 'Copy link'; }, 1200);
      } catch {
        copyButton.textContent = 'Copy failed';
        setTimeout(() => { copyButton.textContent = 'Copy link'; }, 1200);
      }
    });
  }

  function typesetAll(container: HTMLElement) {
    container.querySelectorAll<HTMLElement>('[data-typeset]').forEach((e) => typeset(e));
  }

  function renderPage(container: HTMLElement, review: Review) {
    const banner = buildEthicsBanner(review);
    const speedread = buildSpeedread(review);
    const toggle = buildModeToggle();
    const judgment = buildJudgment(review);
    const questions = buildKeyQuestions(review);
    const abstract = buildAbstract(review);
    const limits = buildLimits(review);
    const raw = buildRaw(review);

    const stack = el('div', { class: 'review-content-stack' }, [
      banner,
      speedread,
      toggle,
      judgment,
      questions,
      abstract,
      limits,
      raw,
    ].filter((n): n is HTMLElement => n != null));

    mount(container, stack);
    attachModeToggle(stack);
    attachCopyLink(container);
    typesetAll(container);
  }

  function errorState(title: string, detail: string): HTMLElement {
    return el('div', { class: 'state error' }, [
      el('strong', {}, title),
      el('span', {}, detail),
    ]);
  }

  async function main() {
    const container = document.getElementById('review-detail');
    const id = new URLSearchParams(window.location.search).get('id');
    if (!container) return;

    if (!id) {
      mount(container, errorState('Missing review ID', 'No ?id= parameter supplied.'));
      return;
    }

    let review: Review;
    try {
      review = await dataClient.getReview(id);
    } catch (e) {
      mount(container, errorState('Failed to load review', e instanceof Error ? e.message : String(e)));
      return;
    }

    document.title = `${review.title} \u2014 OpenAgent.review`;
    renderPage(container, review);

    // If the URL ends in #questions, scroll to the key-questions section after render.
    if (window.location.hash === '#questions') {
      setTimeout(() => {
        document.getElementById('questions')?.scrollIntoView({ behavior: 'smooth' });
      }, 120);
    }
  }

  main();
</script>
