---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Review"
  description="AI-generated review of a research paper."
>
  <div class="container">
    <article class="content" id="review-detail">
      <div class="state loading">
        <strong>Loading review</strong>
      </div>
    </article>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { reviewBlock, responseTimeline, responseBlock, stateView } from '../lib/render';
  import { formatDate } from '../lib/utils';
  import type { Review } from '../lib/types';

  function buildHeader(r: Review): HTMLElement {
    const dateStr = formatDate(r.date);
    const reviewUrl = `/day/?date=${encodeURIComponent(r.date)}`;

    const breadcrumb = el('nav', { class: 'breadcrumb', 'aria-label': 'Breadcrumb' }, [
      el('a', { href: '/' }, 'Home'),
      el('span', { class: 'sep' }, '/'),
      el('a', { href: reviewUrl }, dateStr),
      el('span', { class: 'sep' }, '/'),
      el('span', {}, 'Review'),
    ]);

    const meta =
      r.hf_rank != null
        ? el('div', { class: 'forum-meta' }, [
            el('span', { class: 'tag tag-rank' }, `HF Daily #${r.hf_rank}`),
          ])
        : null;

    const copyBtn = el(
      'button',
      { class: 'btn', type: 'button', 'aria-label': 'Copy link' },
      'Copy link'
    );
    let restoreT: number | undefined;
    copyBtn.addEventListener('click', async () => {
      if (restoreT) {
        clearTimeout(restoreT);
        restoreT = undefined;
      }
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyBtn.textContent = 'Copied ✓';
      } catch {
        copyBtn.textContent = 'Copy failed';
      }
      restoreT = window.setTimeout(() => {
        copyBtn.textContent = 'Copy link';
        restoreT = undefined;
      }, 1400);
    });

    const actions = el('div', { class: 'forum-actions' }, [
      el(
        'a',
        {
          class: 'btn btn-primary',
          href: r.paper_url,
          target: '_blank',
          rel: 'noopener',
        },
        'Read PDF →'
      ),
      el('a', { class: 'btn', href: reviewUrl }, `Browse ${dateStr}`),
      copyBtn,
    ]);

    return el('header', { class: 'forum-header fade-in' }, [
      breadcrumb,
      el('h1', { class: 'forum-title' }, r.title),
      meta,
      actions,
    ]);
  }

  function buildAbstract(r: Review): HTMLElement {
    return el('section', { class: 'forum-note' }, [
      el('div', { class: 'note-heading' }, 'Abstract'),
      el('div', { class: 'note-content' }, el('p', {}, r.summary)),
    ]);
  }

  async function main() {
    const container = document.getElementById('review-detail')!;
    const id = new URLSearchParams(window.location.search).get('id');

    if (!id) {
      mount(container, stateView('error', 'Missing review ID', 'No ?id= parameter supplied.'));
      return;
    }

    let review: Review;
    let response;
    try {
      [review, response] = await Promise.all([
        dataClient.getReview(id),
        dataClient.getResponse(id),
      ]);
    } catch (e) {
      mount(
        container,
        stateView('error', 'Failed to load review', e instanceof Error ? e.message : String(e))
      );
      return;
    }

    document.title = `${review.title} — ureview.ai`;

    const nodes: (Node | string)[] = [
      buildHeader(review),
      buildAbstract(review),
      reviewBlock(review.review),
    ];
    if (response) {
      nodes.push(responseTimeline(), responseBlock(response));
    }
    mount(container, ...nodes);
  }

  main();
</script>
