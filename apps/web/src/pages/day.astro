---
import Layout from '../components/Layout.astro';
---

<Layout
  title="Daily Archive"
  description="Daily archive of AI-generated paper reviews."
>
  <div class="container">
    <section class="content" id="day-reviews">
      <div class="state loading">
        <strong>Loading</strong>
      </div>
    </section>
  </div>
</Layout>

<script>
  import { dataClient } from '../lib/data-client';
  import { el, mount } from '../lib/dom';
  import { paperItem, stateView } from '../lib/render';
  import { formatDate, shiftDate } from '../lib/utils';
  import type { DailyReviewEntry } from '../lib/types';

  function buildDayHeader(date: string, count: number): HTMLElement {
    const prev = shiftDate(date, -1);
    const next = shiftDate(date, 1);

    return el('div', { class: 'day-header fade-in' }, [
      el('div', {}, [
        el('h2', { class: 'day-title' }, formatDate(date)),
        el(
          'div',
          { class: 'day-meta' },
          `${count} paper${count === 1 ? '' : 's'} reviewed`
        ),
      ]),
      el('div', { class: 'day-nav' }, [
        el(
          'a',
          {
            class: 'btn',
            href: `/day/?date=${encodeURIComponent(prev)}`,
            'aria-label': 'Previous day',
          },
          '← Prev'
        ),
        el('a', { class: 'btn', href: '/' }, 'All'),
        el(
          'a',
          {
            class: 'btn',
            href: `/day/?date=${encodeURIComponent(next)}`,
            'aria-label': 'Next day',
          },
          'Next →'
        ),
      ]),
    ]);
  }

  async function main() {
    const container = document.getElementById('day-reviews')!;
    const date = new URLSearchParams(window.location.search).get('date');

    if (!date) {
      mount(
        container,
        stateView('error', 'Missing date', 'No ?date= parameter supplied.')
      );
      return;
    }

    let reviews: DailyReviewEntry[];
    try {
      const data = await dataClient.getDaily(date);
      reviews = data.reviews;
    } catch (e) {
      mount(
        container,
        buildDayHeader(date, 0),
        stateView(
          'error',
          'Failed to load',
          e instanceof Error ? e.message : String(e)
        )
      );
      return;
    }

    document.title = `${formatDate(date)} — Ureview.ai`;

    if (reviews.length === 0) {
      mount(
        container,
        buildDayHeader(date, 0),
        stateView('empty', 'No reviews for this date', 'Try a different day.')
      );
      return;
    }

    const list = el(
      'ul',
      { class: 'paper-list' },
      reviews.map((r, i) => paperItem(r, i))
    );

    mount(container, buildDayHeader(date, reviews.length), list);
  }

  main();
</script>
