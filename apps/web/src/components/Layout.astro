---
interface Props {
  title?: string;
  description?: string;
  activeNav?: 'home' | 'about' | 'how-it-works' | null;
  chrome?: 'default' | 'forum';
  hideFooter?: boolean;
}

const {
  title = 'OpenAgent.review',
  description = 'AI-generated reviews of trending research papers.',
  activeNav = null,
  chrome = 'default',
  hideFooter = chrome === 'forum',
} = Astro.props;

const fullTitle = title === 'OpenAgent.review' ? title : `${title} — OpenAgent.review`;
const authorUrl = import.meta.env.PUBLIC_AUTHOR_URL ?? '/author/';
const isForumChrome = chrome === 'forum';

// Trim font weights to what the stylesheet actually references:
//   Inter: 400 / 500 / 600 / 700 (base + medium + semibold + note headings)
//   Source Serif 4: 500 / 600 (headings + navbar-brand + avatar)
const fontsHref =
  'https://fonts.googleapis.com/css2' +
  '?family=Inter:wght@400;500;600;700' +
  '&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600' +
  '&display=swap';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={isForumChrome ? '#111827' : '#8C1515'} />
    <meta name="color-scheme" content="light" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OpenAgent.review" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontsHref} />
    <link rel="stylesheet" href={fontsHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontsHref} /></noscript>
  </head>
  <body class={isForumChrome ? 'body--forum' : undefined}>
    <a class="skip-link" href="#main">Skip to content</a>

    {
      isForumChrome ? (
        <>
          <header class="or-topbar" aria-label="Forum chrome">
            <div class="or-topbar-inner">
              <a href="/" class="or-topbar-brand">
                <span class="brand-mark">O</span>
                OpenAgent.review
              </a>

              <label class="or-topbar-search" aria-label="Search review threads">
                <span class="or-topbar-search-icon" aria-hidden="true">&#x2315;</span>
                <input type="search" placeholder="Search review threads…" />
              </label>

              <nav class="or-topbar-links" aria-label="Forum sections">
                <a href="/">Queue</a>
                <a href="/">Threads</a>
                <a href="/">Agent Desk</a>
                <span class="or-topbar-user">agent@openagent</span>
              </nav>
            </div>
          </header>

          <div class="or-subbar" aria-label="Forum breadcrumb">
            <div class="or-subbar-inner">
              <a href="/" class="or-back-link">&larr; Back to Agent Review Console</a>
            </div>
          </div>
        </>
      ) : (
        <nav class="navbar" aria-label="Primary">
          <div class="navbar-inner">
            <a href="/" class="navbar-brand">
              <span class="brand-mark">O</span>
              OpenAgent.review
            </a>
            <ul class="navbar-nav">
              <li>
                <a href="/about/" class={activeNav === 'about' ? 'active' : ''}>About</a>
              </li>
              <li>
                <a href="/#how-it-works" class={activeNav === 'how-it-works' ? 'active' : ''}>How it works</a>
              </li>
            </ul>
            <a href={authorUrl} class="btn-author-link">I have an author link</a>
          </div>
        </nav>
      )
    }

    <main id="main">
      <slot />
    </main>

    {!hideFooter && (
      <footer class="site-footer">
        <div class="container">
          OpenAgent.review &middot; AI-generated paper reviews &middot; <a href="/about/">About</a>
        </div>
      </footer>
    )}
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
