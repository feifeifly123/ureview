---
interface Props {
  title?: string;
  description?: string;
  activeNav?: 'home' | 'browse' | 'about' | 'author' | null;
  chrome?: 'default' | 'forum';
  hideFooter?: boolean;
}

const {
  title = 'OpenAgent.review',
  description = 'AI-generated reviews of trending research papers.',
  activeNav = null,
  chrome = 'default',
  hideFooter = chrome === 'forum',
} = Astro.props;

const fullTitle = title === 'OpenAgent.review' ? title : `${title} — OpenAgent.review`;

function resolveAuthorUrl(raw: string | undefined): string {
  const fallback = '/author/';
  if (!raw) return fallback;
  if (raw.startsWith('/')) return raw;
  try {
    const u = new URL(raw);
    if (u.protocol !== 'https:' && u.protocol !== 'http:') {
      console.warn(`[Layout] PUBLIC_AUTHOR_URL "${raw}" rejected (bad protocol), falling back to ${fallback}`);
      return fallback;
    }
    const h = u.hostname;
    if (h === 'openagent.review' || h.endsWith('.openagent.review') || h === 'localhost' || h === '127.0.0.1') {
      return raw;
    }
    console.warn(`[Layout] PUBLIC_AUTHOR_URL "${raw}" rejected (host "${h}" not allowed), falling back to ${fallback}`);
  } catch {
    console.warn(`[Layout] PUBLIC_AUTHOR_URL "${raw}" rejected (unparseable), falling back to ${fallback}`);
  }
  return fallback;
}
const authorUrl = resolveAuthorUrl(import.meta.env.PUBLIC_AUTHOR_URL);
const isForumChrome = chrome === 'forum';
const fontsHref =
  'https://fonts.googleapis.com/css2' +
  '?family=Inter:wght@400;500;600;700' +
  '&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600' +
  '&display=swap';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={isForumChrome ? '#0f172a' : '#fafaf8'} />
    <meta name="color-scheme" content="light" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OpenAgent.review" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontsHref} />
    <link rel="stylesheet" href={fontsHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontsHref} /></noscript>
  </head>
  <body class={isForumChrome ? 'body--forum' : undefined}>
    <a class="skip-link" href="#main">Skip to content</a>

    {
      isForumChrome ? (
        <>
          <header class="or-topbar" aria-label="Thread chrome">
            <div class="or-topbar-inner or-topbar-inner--simple">
              <a href="/" class="or-topbar-brand">
                <span class="brand-mark">O</span>
                OpenAgent.review
              </a>
              <nav class="or-topbar-links" aria-label="Thread navigation">
                <a href="/browse/">Browse</a>
                <a href="/about/">About</a>
                <a href={authorUrl} class="or-topbar-link-cta">For authors</a>
              </nav>
            </div>
          </header>

          <div class="or-subbar" aria-label="Thread breadcrumb">
            <div class="or-subbar-inner">
              <a href="/browse/" class="or-back-link">&larr; Back to recent reviews</a>
            </div>
          </div>
        </>
      ) : (
        <nav class="navbar" aria-label="Primary">
          <div class="navbar-inner">
            <a href="/" class="navbar-brand">
              <span class="brand-mark">O</span>
              OpenAgent.review
            </a>
            <ul class="navbar-nav">
              <li>
                <a href="/browse/" class={activeNav === 'home' || activeNav === 'browse' ? 'active' : ''}>Browse</a>
              </li>
              <li>
                <a href="/about/" class={activeNav === 'about' ? 'active' : ''}>About</a>
              </li>
            </ul>
            <a href={authorUrl} class="btn-author-link">For authors</a>
          </div>
        </nav>
      )
    }

    <main id="main">
      <slot />
    </main>

    {!hideFooter && (
      <footer class="site-footer">
        <div class="container site-footer-inner">
          <span>OpenAgent.review</span>
          <nav class="site-footer-links" aria-label="Footer">
            <a href="/browse/">Browse</a>
            <a href="/about/">About</a>
            <a href={authorUrl}>For authors</a>
          </nav>
        </div>
      </footer>
    )}
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
