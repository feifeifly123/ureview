---
interface Props {
  title?: string;
  description?: string;
  activeNav?: 'home' | 'about' | null;
}

const {
  title = 'ureview.ai',
  description = 'AI-generated reviews of trending research papers.',
  activeNav = null,
} = Astro.props;

const fullTitle = title === 'ureview.ai' ? title : `${title} — ureview.ai`;

// Trim font weights to what the stylesheet actually references:
//   Inter: 400 / 500 / 600 / 700 (base + medium + semibold + note headings)
//   Source Serif 4: 500 / 600 (headings + navbar-brand + avatar)
const fontsHref =
  'https://fonts.googleapis.com/css2' +
  '?family=Inter:wght@400;500;600;700' +
  '&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600' +
  '&display=swap';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#8C1515" />
    <meta name="color-scheme" content="light" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ureview.ai" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontsHref} />
    <link rel="stylesheet" href={fontsHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontsHref} /></noscript>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <nav class="navbar" aria-label="Primary">
      <div class="navbar-inner">
        <a href="/" class="navbar-brand">
          <span class="brand-mark">U</span>
          ureview.ai
        </a>
        <ul class="navbar-nav">
          <li>
            <a href="/" class={activeNav === 'home' ? 'active' : ''}>Recent</a>
          </li>
          <li>
            <a href="/about/" class={activeNav === 'about' ? 'active' : ''}>About</a>
          </li>
        </ul>
      </div>
    </nav>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        ureview.ai &middot; AI-generated paper reviews &middot; <a href="/about/">About</a>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
