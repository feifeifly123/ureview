{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review.schema.json",
  "title": "PaperReview",
  "type": "object",
  "required": ["id", "slug", "date", "title", "paper_url", "abstract", "ai_review", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-.+" },
    "slug": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "title": { "type": "string" },
    "paper_url": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "hf_rank": { "type": "integer", "minimum": 1 },
    "abstract": { "type": "string" },
    "ai_review": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
