{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review.schema.json",
  "title": "PaperReview",
  "type": "object",
  "required": ["id", "slug", "date", "title", "paper_url", "summary", "review", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-.+" },
    "slug": { "type": "string" },
    "date": { "type": "string", "format": "date" },
    "title": { "type": "string" },
    "paper_url": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "hf_rank": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string" },
    "review": {
      "type": "object",
      "required": ["score", "confidence", "strengths", "weaknesses", "final_comment"],
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 10 },
        "confidence": { "type": "integer", "minimum": 1, "maximum": 5 },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "final_comment": { "type": "string" }
      },
      "additionalProperties": false
    },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
