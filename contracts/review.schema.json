{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review.schema.json",
  "title": "MathPaperReview",
  "description": "An AI-evaluated math paper. All metadata fields come from arxiv; the only human-uploaded content is ai_proof_review.",
  "type": "object",
  "required": [
    "id",
    "date",
    "title",
    "paper_url",
    "abstract",
    "arxiv_categories",
    "authors",
    "ai_proof_review",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^(\\d{4}\\.\\d{4,5}|[a-z-]+/\\d{7})$" },
    "date": { "type": "string", "format": "date" },
    "title": { "type": "string", "minLength": 1 },
    "paper_url": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "arxiv_categories": {
      "type": "array",
      "items": { "type": "string", "pattern": "^math\\." },
      "minItems": 1,
      "description": "At least one math.* category required; non-math papers are out of scope."
    },
    "authors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "published": { "type": ["string", "null"] },
    "abstract": { "type": "string", "minLength": 1 },
    "ai_proof_review": {
      "type": "string",
      "minLength": 50,
      "description": "Long-form AI evaluation of the paper's proof. Markdown + LaTeX (KaTeX delimiters) supported."
    },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
