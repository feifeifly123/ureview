{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "latest.schema.json",
  "title": "LatestIndex",
  "type": "object",
  "required": ["generated_at", "reviews"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "title", "authors", "arxiv_categories", "review_lede", "impact_if_true", "proof_correctness"],
        "properties": {
          "id": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "title": { "type": "string" },
          "authors": { "type": "array", "items": { "type": "string" } },
          "arxiv_categories": { "type": "array", "items": { "type": "string", "pattern": "^math\\." } },
          "published": { "type": ["string", "null"] },
          "updated_at": { "type": "string", "format": "date-time" },
          "review_lede": {
            "type": "string",
            "description": "First sentence(s) of ai_proof_review, truncated for listings."
          },
          "impact_if_true": { "type": "string", "enum": ["max", "high", "medium", "low", "minimal"] },
          "proof_correctness": { "type": "string", "enum": ["max", "high", "medium", "low", "minimal"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
