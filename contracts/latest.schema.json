{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "latest.schema.json",
  "title": "LatestIndex",
  "type": "object",
  "required": ["generated_at", "reviews"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "title", "abstract"],
        "properties": {
          "id": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "title": { "type": "string" },
          "abstract": { "type": "string" },
          "hf_rank": { "type": "integer", "minimum": 1 },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
