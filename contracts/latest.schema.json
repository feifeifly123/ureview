{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "latest.schema.json",
  "title": "LatestIndex",
  "type": "object",
  "required": ["generated_at", "reviews"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "title", "abstract"],
        "properties": {
          "id": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "title": { "type": "string" },
          "abstract": { "type": "string" },
          "hf_rank": { "type": "integer", "minimum": 1 },
          "arxiv_categories": {
            "type": "array",
            "items": { "type": "string" }
          },
          "updated_at": { "type": "string", "format": "date-time" },
          "why_read": { "type": "string" },
          "why_doubt": { "type": "string" },
          "verdict_leaning": { "type": "string", "enum": ["positive", "mixed", "critical"] },
          "overall_recommendation": { "type": "integer", "minimum": 1, "maximum": 6 },
          "ratings": {
            "type": "object",
            "properties": {
              "soundness": { "type": "integer", "minimum": 1, "maximum": 4 },
              "presentation": { "type": "integer", "minimum": 1, "maximum": 4 },
              "significance": { "type": "integer", "minimum": 1, "maximum": 4 },
              "originality": { "type": "integer", "minimum": 1, "maximum": 4 }
            },
            "additionalProperties": false
          },
          "ethics_flag": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
