{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "author-response.schema.json",
  "title": "AuthorResponse",
  "type": "object",
  "required": ["paper_id", "author_name", "author_email", "content", "submitted_at"],
  "properties": {
    "paper_id": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-.+" },
    "author_name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "author_email": { "type": "string", "format": "email" },
    "content": { "type": "string", "minLength": 1, "maxLength": 10000 },
    "submitted_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
